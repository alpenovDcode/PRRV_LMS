generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserTariff {
  VR // Vostrebovannyi
  LR // Lider Rynka
  SR // Samostoyatelnyi
}

model User {
  id                      String                  @id @default(uuid())
  email                   String                  @unique
  passwordHash            String                  @map("password_hash")
  fullName                String?                 @map("full_name")
  avatarUrl               String?                 @map("avatar_url")
  role                    UserRole                @default(student)
  tariff                  UserTariff?             @map("tariff")
  sessionId               String?                 @map("session_id")
  isBlocked               Boolean                 @default(false) @map("is_blocked")
  frozenUntil             DateTime?               @map("frozen_until")
  emailVerified           Boolean                 @default(false) @map("email_verified")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  passwordResetExpires    DateTime?               @map("password_reset_expires")
  passwordResetToken      String?                 @map("password_reset_token")
  about                   String?
  phone                   String?
  telegram                String?
  track                   String?
  lastActiveAt            DateTime?               @map("last_active_at")
  auditLogs               AuditLog[]
  courses                 Course[]                @relation("CourseAuthor")
  enrollments             Enrollment[]
  groupMembers            GroupMember[]
  reviewedHomeworkHistory HomeworkHistory[]       @relation("HomeworkHistoryReviewer")
  reviewedHomework        HomeworkSubmission[]    @relation("HomeworkReviewer")
  homework                HomeworkSubmission[]
  lessonComments          LessonComment[]
  progress                LessonProgress[]
  uploadedMedia           MediaFile[]             @relation("MediaUploader")
  notificationPreference  NotificationPreference?
  notifications           Notification[]
  reviewedQuizzes         QuizAttempt[]           @relation("QuizReviewer")
  quizAttempts            QuizAttempt[]
  twoFactorAuth           TwoFactorAuth?
  userSessions            UserSession[]
  errorLogs               ErrorLog[]
  loginTokens             LoginToken[]
  keywords                String[]                @default([])  // Накопленные ключевые слова из форм
  certificates            Certificate[]
  broadcastsCreated       Broadcast[]             @relation("BroadcastAuthor")
  broadcastsReceived      BroadcastRecipient[]    @relation("BroadcastRecipientUser")
  questionsAsked          Question[]              @relation("QuestionStudent")
  questionsAssigned       Question[]              @relation("QuestionCurator")
  questionMessages        QuestionMessage[]

  @@index([email])
  @@map("users")
}

model LoginToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("login_tokens")
}

model Course {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  description String?
  coverImage  String?      @map("cover_image")
  isPublished Boolean      @default(false) @map("is_published")
  authorId    String       @map("author_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  autoIssueCertificate Boolean @default(false) @map("auto_issue_certificate")
  certificateTemplateId String? @map("certificate_template_id")
  author      User         @relation("CourseAuthor", fields: [authorId], references: [id])
  enrollments Enrollment[]
  groups      Group[]
  modules     Module[]
  certificateTemplates CertificateTemplate[]
  certificates Certificate[]

  @@index([slug])
  @@index([authorId])
  @@map("courses")
}

model Module {
  id             String       @id @default(uuid())
  courseId       String       @map("course_id")
  parentId       String?      @map("parent_id")
  title          String
  orderIndex     Int          @map("order_index")
  allowedTariffs UserTariff[] @map("allowed_tariffs")
  allowedTracks  String[]     @map("allowed_tracks")
  allowedGroups  String[]     @map("allowed_groups")
  openAt         DateTime?    @map("open_at")
  openAfterAmount Int?        @map("open_after_amount")
  openAfterUnit  String?      @map("open_after_unit") // 'days', 'weeks'
  openAfterEvent String?      @map("open_after_event") // 'track_definition'
  trackSettings  Json?        @map("track_settings")
  groupSettings  Json?        @map("group_settings")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  lessons        Lesson[]
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parent         Module?      @relation("ModuleHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Module[]     @relation("ModuleHierarchy")

  @@index([courseId])
  @@index([parentId])
  @@map("modules")
}

model Lesson {
  id                 String               @id @default(uuid())
  moduleId           String               @map("module_id")
  title              String
  type               LessonType
  content            Json?
  videoId            String?              @map("video_id")
  videoDuration      Int?                 @map("video_duration")
  thumbnailUrl       String?              @map("thumbnail_url")
  isFree             Boolean              @default(false) @map("is_free")
  isStopLesson       Boolean              @default(false) @map("is_stop_lesson")
  dripRule           Json?                @map("drip_rule")
  settings           Json?
  orderIndex         Int                  @map("order_index")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  quizMaxAttempts    Int?                 @default(3) @map("quiz_max_attempts")
  quizPassingScore   Int?                 @map("quiz_passing_score")
  quizRequiresReview Boolean              @default(false) @map("quiz_requires_review")
  quizTimeLimit      Int?                 @map("quiz_time_limit")
  aiPrompt           String?              @db.Text @map("ai_prompt")
  aiContext          String?              @db.Text @map("ai_context")
  autoResponse       String?              @db.Text @map("auto_response")
  hasImageAnalysis   Boolean              @default(false) @map("has_image_analysis")
  homework           HomeworkSubmission[]
  comments           LessonComment[]
  LessonMedia        LessonMedia[]
  progress           LessonProgress[]
  module             Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizAttempts       QuizAttempt[]
  landingBlocks      LandingBlock[]

  @@index([moduleId])
  @@map("lessons")
}

model Enrollment {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  courseId          String           @map("course_id")
  status            EnrollmentStatus @default(active)
  startDate         DateTime         @map("start_date")
  expiresAt         DateTime?        @map("expires_at")
  restrictedModules String[]         @default([]) @map("restricted_modules")
  forcedModules     String[]         @default([]) @map("forced_modules")
  restrictedLessons String[]         @default([]) @map("restricted_lessons")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  course            Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  courseId    String?       @map("course_id")
  startDate   DateTime?     @map("start_date")
  members     GroupMember[]
  course      Course?       @relation(fields: [courseId], references: [id])

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model LessonProgress {
  userId      String         @map("user_id")
  lessonId    String         @map("lesson_id")
  status      ProgressStatus @default(not_started)
  watchedTime Int            @default(0) @map("watched_time")
  completedAt DateTime?      @map("completed_at")
  lastUpdated DateTime       @default(now()) @updatedAt @map("last_updated")
  rating      Int?           @map("rating")
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model HomeworkSubmission {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  lessonId       String?           @map("lesson_id")
  landingBlockId String?           @map("landing_block_id")
  content        String?
  files          Json?
  curatorFiles   Json?             @map("curator_files")
  status         HomeworkStatus    @default(pending)
  curatorComment String?            @map("curator_comment")
  curatorAudioUrl String?           @map("curator_audio_url")
  curatorId      String?            @map("curator_id")
  reviewedAt     DateTime?         @map("reviewed_at")
  
  // Auto-Review fields
  autoResponseScheduledAt DateTime? @map("auto_response_scheduled_at")
  responseTemplateIndex   Int?      @map("response_template_index")
  
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  history        HomeworkHistory[]
  curator        User?             @relation("HomeworkReviewer", fields: [curatorId], references: [id])
  lesson         Lesson?           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  landingBlock   LandingBlock?     @relation(fields: [landingBlockId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@index([landingBlockId])
  @@index([status])
  @@map("homework_submissions")
}

model HomeworkHistory {
  id             String             @id @default(uuid())
  submissionId   String             @map("submission_id")
  content        String?
  files          Json?
  status         HomeworkStatus
  curatorComment String?            @map("curator_comment")
  curatorAudioUrl String?           @map("curator_audio_url")
  curatorId      String?            @map("curator_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  curator        User?              @relation("HomeworkHistoryReviewer", fields: [curatorId], references: [id])
  submission     HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([createdAt])
  @@map("homework_history")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  link      String?  @map("link")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model QuizAttempt {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  lessonId       String    @map("lesson_id")
  attemptNumber  Int       @map("attempt_number")
  answers        Json
  score          Int?
  isPassed       Boolean   @default(false) @map("is_passed")
  isAutoGraded   Boolean   @default(false) @map("is_auto_graded")
  requiresReview Boolean   @default(false) @map("requires_review")
  curatorComment String?   @map("curator_comment")
  curatorId      String?   @map("curator_id")
  startedAt      DateTime  @default(now()) @map("started_at")
  submittedAt    DateTime? @map("submitted_at")
  timeSpent      Int?      @map("time_spent")
  curator        User?     @relation("QuizReviewer", fields: [curatorId], references: [id])
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([lessonId])
  @@index([isPassed])
  @@map("quiz_attempts")
}

model MediaFile {
  id               String        @id @default(uuid())
  name             String
  originalName     String        @map("original_name")
  mimeType         String        @map("mime_type")
  size             Int
  url              String
  signedUrl        String?       @map("signed_url")
  signedUrlExpires DateTime?     @map("signed_url_expires")
  uploadedById     String        @map("uploaded_by_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  lessonMedia      LessonMedia[]
  uploadedBy       User          @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([mimeType])
  @@map("media_files")
}

model LessonMedia {
  id         String    @id @default(uuid())
  lessonId   String    @map("lesson_id")
  mediaId    String    @map("media_id")
  orderIndex Int       @default(0) @map("order_index")
  createdAt  DateTime  @default(now()) @map("created_at")
  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  media      MediaFile @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([lessonId, mediaId])
  @@index([lessonId])
  @@map("lesson_media")
}

model LessonComment {
  id        String          @id @default(uuid())
  lessonId  String          @map("lesson_id")
  userId    String          @map("user_id")
  parentId  String?         @map("parent_id")
  content   String
  isDeleted Boolean         @default(false) @map("is_deleted")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent    LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   LessonComment[] @relation("CommentReplies")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
  @@index([parentId])
  @@map("lesson_comments")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  channels    Json
  preferences Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model UserSession {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  sessionId      String   @map("session_id")
  deviceName     String?  @map("device_name")
  deviceType     String?  @map("device_type")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  isActive       Boolean  @default(true) @map("is_active")
  lastActivityAt DateTime @default(now()) @updatedAt @map("last_activity_at")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([userId])
  @@index([isActive])
  @@map("user_sessions")
}

model TwoFactorAuth {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  secret      String
  isEnabled   Boolean  @default(false) @map("is_enabled")
  backupCodes String[] @map("backup_codes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_auth")
}

enum TwoFactorMethod {
  totp
  sms
  email

  @@map("two_factor_method")
}

model ErrorLog {
  id          String        @id @default(uuid())
  groupId     String?       @map("group_id")
  message     String
  stack       String?       @db.Text
  url         String?
  userAgent   String?       @map("user_agent")
  userId      String?       @map("user_id")
  sessionId   String?       @map("session_id")
  severity    ErrorSeverity @default(error)
  status      ErrorStatus   @default(new)
  metadata    Json?
  browserInfo Json?         @map("browser_info")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  group ErrorGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([userId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("error_logs")
}

model ErrorGroup {
  id            String        @id @default(uuid())
  fingerprint   String        @unique
  title         String
  message       String
  count         Int           @default(1)
  status        ErrorStatus   @default(new)
  severity      ErrorSeverity @default(error)
  firstOccurred DateTime      @default(now()) @map("first_occurred")
  lastOccurred  DateTime      @default(now()) @map("last_occurred")
  resolvedAt    DateTime?     @map("resolved_at")
  resolvedBy    String?       @map("resolved_by")
  notes         String?       @db.Text

  errors ErrorLog[]

  @@index([fingerprint])
  @@index([status])
  @@index([lastOccurred])
  @@map("error_groups")
}

enum ErrorSeverity {
  critical
  error
  warning
  info

  @@map("error_severity")
}

enum ErrorStatus {
  new
  investigating
  resolved
  ignored

  @@map("error_status")
}

enum UserRole {
  student
  admin
  curator
}

enum LessonType {
  video
  text
  quiz
  track_definition
  intermediate_survey
  certification_form
}

enum EnrollmentStatus {
  active
  expired
  frozen
}

enum ProgressStatus {
  not_started
  in_progress
  completed
  failed
}

enum HomeworkStatus {
  pending
  approved
  rejected
}

model VideoLibrary {
  id           String   @id @default(uuid())
  title        String
  cloudflareId String   @unique @map("cloudflare_id")
  duration     Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("video_library")
}

model LandingPage {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  isPublished Boolean        @default(false) @map("is_published")
  views       Int            @default(0)
  settings    Json?          // Stores Bitrix integration and other page-specific settings
  blocks      LandingBlock[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("landing_pages")
}

model LandingBlock {
  id                String               @id @default(uuid())
  pageId            String               @map("page_id")
  type              String               // 'text', 'form', 'video'
  content           Json
  design            Json?                // Background, text color, padding, etc.
  settings          Json?                // UTM tags, openAt
  responseTemplates String[]             @default([]) @map("response_templates")
  orderIndex        Int                  @map("order_index")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  lessonId          String?              @map("lesson_id")
  lesson            Lesson?              @relation(fields: [lessonId], references: [id])
  page              LandingPage          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  submissions       HomeworkSubmission[]

  @@index([pageId])
  @@index([lessonId])
  @@map("landing_blocks")
}

model CertificateTemplate {
  id              String   @id @default(uuid())
  courseId        String?  @map("course_id")
  name            String
  imageUrl        String   @map("image_url")
  fieldConfig     Json     @map("field_config")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  course          Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificates    Certificate[]
  
  @@index([courseId])
  @@map("certificate_templates")
}

model Certificate {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  courseId            String   @map("course_id")
  templateId          String   @map("template_id")
  certificateNumber   String   @unique @map("certificate_number")
  pdfUrl              String   @map("pdf_url")
  issuedAt            DateTime @default(now()) @map("issued_at")
  
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  template            CertificateTemplate @relation(fields: [templateId], references: [id])
  
  @@index([userId])
  @@index([courseId])
  @@index([certificateNumber])
  @@map("certificates")
}

model Broadcast {
  id          String   @id @default(uuid())
  authorId    String   @map("author_id")
  title       String
  message     String   @db.Text
  channels    String[] // ['lms', 'email']
  targets     Json     // { roles, groupIds, tariffs, tracks }
  recipients  Int      @default(0)
  sentCount   Int      @default(0) @map("sent_count")
  failedCount Int      @default(0) @map("failed_count")
  status      String   @default("pending") // pending, sending, completed, failed
  sentAt      DateTime @default(now()) @map("sent_at")
  author      User                 @relation("BroadcastAuthor", fields: [authorId], references: [id])
  recipientLogs BroadcastRecipient[]

  @@index([authorId])
  @@index([sentAt])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id          String    @id @default(uuid())
  broadcastId String    @map("broadcast_id")
  userId      String    @map("user_id")
  email       String?
  lmsStatus   String?   @map("lms_status")   // sent | failed | skipped
  emailStatus String?   @map("email_status") // sent | failed | skipped
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at")
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user        User      @relation("BroadcastRecipientUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([userId])
  @@map("broadcast_recipients")
}

enum QuestionStatus {
  open
  in_progress
  answered
  closed

  @@map("question_status")
}

model Question {
  id              String            @id @default(uuid())
  studentId       String            @map("student_id")
  curatorId       String?           @map("curator_id")
  subject         String
  lessonId        String?           @map("lesson_id")
  status          QuestionStatus    @default(open)
  rating          Int?
  ratingComment   String?           @map("rating_comment") @db.Text
  firstResponseAt DateTime?         @map("first_response_at")
  closedAt        DateTime?         @map("closed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  student         User              @relation("QuestionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  curator         User?             @relation("QuestionCurator", fields: [curatorId], references: [id])
  messages        QuestionMessage[]

  @@index([studentId])
  @@index([curatorId])
  @@index([status])
  @@index([createdAt])
  @@map("questions")
}

model QuestionMessage {
  id          String    @id @default(uuid())
  questionId  String    @map("question_id")
  authorId    String    @map("author_id")
  content     String    @db.Text
  attachments Json?
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])

  @@index([questionId, createdAt])
  @@index([authorId])
  @@map("question_messages")
}

model EmailTemplate {
  id          String   @id @default(uuid())
  event       String
  name        String
  subject     String
  body        String   @db.Text
  variables   Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

// =================================================================
// Bot platform (Telegram-first SaleBot/BotHelp replacement)
// All tables are isolated under tg_* prefix and do not touch
// the existing LMS schema. Single-tenant for now: the school IS
// the only org. Multi-tenant can be added later via orgId.
// =================================================================

model TgBot {
  id              String   @id @default(uuid())
  // Encrypted Telegram bot token. NEVER store the raw token.
  // Encryption: AES-256-GCM, see lib/tg/crypto.ts
  tokenEncrypted  String   @map("token_encrypted") @db.Text
  // First 8 chars of the token (before ':'), kept for display only.
  tokenPrefix     String   @map("token_prefix")
  // Bot identity from getMe.
  botUserId       String   @unique @map("bot_user_id")
  username        String
  title           String
  // Random secret token used to verify Telegram webhook calls
  // (X-Telegram-Bot-Api-Secret-Token header).
  webhookSecret   String   @map("webhook_secret")
  webhookUrl      String?  @map("webhook_url")
  isActive        Boolean  @default(true) @map("is_active")
  // Default flow triggered by /start without payload (optional).
  defaultStartFlowId String? @map("default_start_flow_id")
  // Bot-wide variables ("project.x") and constants. Editable in admin.
  // Both are {key: value} JSON objects. Used by the expression engine
  // when a template references `{{project.x}}` or `{{const.x}}`.
  projectVariables Json    @default("{}") @map("project_variables")
  constants       Json     @default("{}")
  // IANA tz; used by date helpers (current_date, weekday, etc.).
  // null = UTC. Default Moscow.
  timezone        String?  @default("Europe/Moscow")
  // Telegram chat_ids of admins whose inbound media is auto-captured
  // into the media library. Empty list = no auto-capture. Set this on
  // bot creation in the admin UI.
  adminChatIds    String[] @default([]) @map("admin_chat_ids")
  // Aggregate stats kept in sync by tg core for fast dashboards.
  subscriberCount Int      @default(0) @map("subscriber_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  subscribers     TgSubscriber[]
  messages        TgMessage[]
  flows           TgFlow[]
  broadcasts      TgBroadcast[]
  trackingLinks   TgTrackingLink[]
  events          TgEvent[]
  mediaFiles      TgMediaFile[]
  lists           TgList[]
  customFields    TgCustomField[]

  @@index([username])
  @@map("tg_bots")
}

model TgSubscriber {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Telegram numeric IDs come as int64; we store as string for safety.
  chatId          String   @map("chat_id")
  tgUserId        String   @map("tg_user_id")
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  username        String?
  languageCode    String?  @map("language_code")
  // Set true if Telegram returns 403 (user blocked the bot).
  isBlocked       Boolean  @default(false) @map("is_blocked")
  // Free-form tags. Single-tenant per-bot — keep it simple.
  tags            String[] @default([])
  // Arbitrary key/value variables set by flow nodes or API.
  variables       Json     @default("{}")
  // First/last touch attribution.
  firstTouchSlug  String?  @map("first_touch_slug")
  firstTouchAt    DateTime? @map("first_touch_at")
  lastTouchSlug   String?  @map("last_touch_slug")
  lastTouchAt     DateTime? @map("last_touch_at")
  lastSeenAt      DateTime? @map("last_seen_at")
  subscribedAt    DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")

  // -- Position in funnel (SaleBot "позиция воронки") -------------------
  // The latest Step (positional message-node) the subscriber walked into.
  // Used to:
  //   1. Display where the subscriber currently is in any funnel
  //   2. Auto-cancel side-effect/dozhim runs originating from a previous
  //      position when the subscriber moves to a new one.
  // null = subscriber has never reached a positional node.
  currentPositionFlowId String? @map("current_position_flow_id")
  currentPositionNodeId String? @map("current_position_node_id")
  currentPositionAt     DateTime? @map("current_position_at")

  // List of "flowId:nodeId" pairs whose triggers fired with onlyOnce=true.
  // Prevents re-entry. Empty in practice for most subscribers.
  firedOnceTriggers     String[] @default([]) @map("fired_once_triggers")

  // Typed custom fields ("доп. поля" in SaleBot terms). Stored as
  // {key: value} with schema defined at the bot level (TgCustomField,
  // added in Iter 2). For Iter 1 this is just a free-form JSON bag —
  // wait_reply nodes can save into it via `saveAs: "field.<key>"`.
  customFields    Json     @default("{}") @map("custom_fields")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages        TgMessage[]
  flowRuns        TgFlowRun[]
  events          TgEvent[]
  broadcastDeliveries TgBroadcastRecipient[]
  lists           TgSubscriberList[]

  @@unique([botId, chatId])
  @@index([botId, isBlocked])
  @@index([botId, lastSeenAt])
  @@index([botId, currentPositionFlowId, currentPositionNodeId])
  @@index([tags], type: Gin)
  @@map("tg_subscribers")
}

model TgMessage {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  subscriberId    String   @map("subscriber_id")
  // 'in' = received from user, 'out' = sent by bot.
  direction       String
  // Telegram message_id from result (out) or update (in).
  tgMessageId     String?  @map("tg_message_id")
  // Raw text or caption.
  text            String?  @db.Text
  // For media: 'photo' | 'video' | 'document' | 'voice' | etc.
  mediaType       String?  @map("media_type")
  mediaFileId     String?  @map("media_file_id")
  // Inline-button payload if message is a callback_query result.
  callbackData    String?  @map("callback_data")
  // Source: flow run, broadcast, manual operator reply, inbound.
  sourceType      String?  @map("source_type")
  sourceId        String?  @map("source_id")
  // Raw Telegram payload (truncated) for diagnostics.
  rawPayload      Json?    @map("raw_payload")
  createdAt       DateTime @default(now()) @map("created_at")

  bot             TgBot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([subscriberId, createdAt])
  @@map("tg_messages")
}

model TgFlow {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  name            String
  description     String?
  // Graph definition. See lib/tg/flow-schema.ts for the contract.
  // Shape: { nodes: TgFlowNode[], startNodeId: string, version: number }
  graph           Json
  isActive        Boolean  @default(true) @map("is_active")
  // Trigger config — array of trigger descriptors evaluated on
  // every inbound update. See lib/tg/flow-schema.ts.
  triggers        Json     @default("[]")
  // Aggregate stats updated by flow engine for fast dashboards.
  totalEntered    Int      @default(0) @map("total_entered")
  totalCompleted  Int      @default(0) @map("total_completed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  runs            TgFlowRun[]

  @@index([botId, isActive])
  @@map("tg_flows")
}

model TgFlowRun {
  id              String   @id @default(uuid())
  flowId          String   @map("flow_id")
  subscriberId    String   @map("subscriber_id")
  // Current node pointer. null until first step is queued.
  currentNodeId   String?  @map("current_node_id")
  // Engine state: queued | running | waiting_reply | sleeping | completed | failed | cancelled
  status          String   @default("queued")
  // For 'sleeping' and 'waiting_reply' — when to wake up / time out.
  resumeAt        DateTime? @map("resume_at")
  // For 'waiting_reply' — variable name to store the reply into.
  waitingForVar   String?  @map("waiting_for_var")
  // Per-run scratch storage (used by ai_reply, http_request results, etc).
  context         Json     @default("{}")
  // Diagnostic: last error if status=failed.
  lastError       String?  @map("last_error") @db.Text
  // The positional node ID this run was scheduled FROM. When the
  // subscriber advances to a new positional node, any sleeping/waiting
  // run with positionGroupId == old position is auto-cancelled.
  // null = run is not tied to a position (top-level trigger, broadcast,
  // CRM event etc.) and is immune to position-change cancellation.
  positionGroupId String?  @map("position_group_id")
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")

  flow            TgFlow        @relation(fields: [flowId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([status, resumeAt])
  @@index([subscriberId, status])
  @@index([flowId, status])
  @@index([subscriberId, positionGroupId, status])
  @@map("tg_flow_runs")
}

model TgBroadcast {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  name            String
  // Message payload (text/buttons/media). See lib/tg/flow-schema.ts.
  message         Json
  // Targeting: { allActive: bool, tagsAny: [], tagsAll: [], excludeTags: [], subscriberIds?: [] }
  filter          Json
  status          String   @default("draft") // draft | scheduled | sending | completed | cancelled | failed
  scheduledAt     DateTime? @map("scheduled_at")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  totalRecipients Int      @default(0) @map("total_recipients")
  sentCount       Int      @default(0) @map("sent_count")
  failedCount     Int      @default(0) @map("failed_count")
  blockedCount    Int      @default(0) @map("blocked_count")
  createdById     String?  @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  recipients      TgBroadcastRecipient[]

  @@index([botId, status])
  @@index([status, scheduledAt])
  @@map("tg_broadcasts")
}

model TgBroadcastRecipient {
  id              String   @id @default(uuid())
  broadcastId     String   @map("broadcast_id")
  subscriberId    String   @map("subscriber_id")
  // pending | sent | failed | blocked | skipped
  status          String   @default("pending")
  tgMessageId     String?  @map("tg_message_id")
  errorCode       Int?     @map("error_code")
  errorMessage    String?  @map("error_message") @db.Text
  attempts        Int      @default(0)
  nextAttemptAt   DateTime? @map("next_attempt_at")
  sentAt          DateTime? @map("sent_at")

  broadcast       TgBroadcast   @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, subscriberId])
  @@index([broadcastId, status])
  @@index([status, nextAttemptAt])
  @@map("tg_broadcast_recipients")
}

model TgTrackingLink {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Short URL-safe payload (<=48 chars) used in t.me/<bot>?start=<slug>.
  slug            String
  name            String
  // Optional flow to enter on /start; if null — default bot flow.
  startFlowId     String?  @map("start_flow_id")
  // Tags applied to subscriber on first touch.
  applyTags       String[] @default([]) @map("apply_tags")
  // Arbitrary UTM-style fields, no fixed schema.
  utm             Json     @default("{}")
  clickCount      Int      @default(0) @map("click_count")
  subscribeCount  Int      @default(0) @map("subscribe_count")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime? @map("expires_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, slug])
  @@map("tg_tracking_links")
}

model TgEvent {
  id              String   @id @default(uuid())
  botId           String?  @map("bot_id")
  subscriberId    String?  @map("subscriber_id")
  // Discriminator. See lib/tg/events.ts for the registry.
  type            String
  // Free-form per-type payload.
  properties      Json     @default("{}")
  occurredAt      DateTime @default(now()) @map("occurred_at")

  bot             TgBot?        @relation(fields: [botId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([botId, type, occurredAt])
  @@index([subscriberId, occurredAt])
  @@map("tg_events")
}

// Lists are dynamic segments — an admin-curated bucket of subscribers
// used for targeting broadcasts and for `list_joined` / `list_left`
// reactive triggers in flows. Conceptually distinct from tags:
//   - Tag = a free-form label attached to a subscriber (denormalized
//     into TgSubscriber.tags[] for cheap GIN-index lookups).
//   - List = an explicit named bucket the subscriber belongs to,
//     with its own analytics counters.
// Mirror of SaleBot's "Списки" feature.
model TgList {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  name            String
  // Optional emoji or short prefix shown in the picker.
  icon            String?
  description     String?
  // Auto-add subscribers matching these tag predicates? Empty = manual.
  // Format: { all?: string[], any?: string[], none?: string[] }
  autoTagRules    Json     @default("{}") @map("auto_tag_rules")
  // Cached counts. Kept fresh by engine writes; can drift slightly
  // under heavy concurrency — fix by recomputing in cron if needed.
  memberCount     Int      @default(0) @map("member_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  members         TgSubscriberList[]

  @@unique([botId, name])
  @@index([botId])
  @@map("tg_lists")
}

// Many-to-many join: which subscribers are in which lists. Created /
// destroyed by addToList() / removeFromList() in lib/tg/lists.ts.
// joinedAt fires the `list_joined` trigger; deletion fires `list_left`.
model TgSubscriberList {
  id              String   @id @default(uuid())
  listId          String   @map("list_id")
  subscriberId    String   @map("subscriber_id")
  joinedAt        DateTime @default(now()) @map("joined_at")

  list            TgList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([listId, subscriberId])
  @@index([subscriberId])
  @@index([listId, joinedAt])
  @@map("tg_subscriber_lists")
}

// Typed custom fields for subscribers. Schema lives here; values live
// in TgSubscriber.customFields (a JSON bag keyed by `key`).
// Each field has a runtime type that the validator + UI honor.
//   text     → free text
//   number   → numeric (validated as parsable float)
//   date     → dd.mm.yyyy
//   email    → email regex
//   phone    → normalised via normalizePhone() helper
//   select   → one of `options[].value`
//   boolean  → "yes"/"no" or true/false
//   url      → URL regex
model TgCustomField {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Identifier used in templates / `wait_reply.saveAs = field.x`.
  // Must match /^[a-z][a-z0-9_]*$/ — enforced in API layer.
  key             String
  // Display label in admin UI.
  label           String
  // Type discriminator (see model docstring).
  type            String
  // Free-text help shown under the field in admin UI.
  description     String?
  // For type=select: array of { value, label }. JSON for flexibility.
  options         Json     @default("[]")
  // Optional regex applied on top of type validation (e.g. an email
  // field restricted to a specific corporate domain).
  validationRegex String?  @map("validation_regex")
  // True = required when an admin opens a subscriber profile. Engine
  // also surfaces required-but-empty fields in the lead sidebar.
  isRequired      Boolean  @default(false) @map("is_required")
  // Display order in lead sidebar.
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, key])
  @@index([botId, sortOrder])
  @@map("tg_custom_fields")
}

// Cached Telegram file_ids. Populated automatically when an admin
// (whitelisted via TgBot.adminChatIds) sends a media message to the
// bot — see lib/tg/inbound.ts. The same file_id can then be reused
// across messages and broadcasts without re-uploading, which is the
// only practical way to send large videos (>50MB upload cap on Bot API).
//
// `kind` mirrors the Telegram media discriminator we send back via
// sendPhoto / sendVideo / sendVoice / sendVideoNote / sendDocument /
// sendAudio / sendAnimation.
model TgMediaFile {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Stable Telegram file_id (valid for the bot that captured it).
  fileId          String   @map("file_id") @db.Text
  // Optional file_unique_id — same across all bots, used for dedup.
  fileUniqueId    String?  @map("file_unique_id")
  // Kind discriminator: photo | video | voice | video_note | document | audio | animation
  kind            String
  // Mime type when Telegram gives it (documents / audio / voice).
  mimeType        String?  @map("mime_type")
  // Bytes (Telegram's reported size; null for very small payloads).
  fileSize        Int?     @map("file_size")
  // For photos: pick the largest variant's dimensions.
  width           Int?
  height          Int?
  duration        Int?
  // Human label assigned in the admin UI. Defaults to original filename
  // for documents, or "voice 2026-05-13 14:32" for sender-recorded media.
  title           String?
  // Original filename when Telegram provides it (document/video/audio).
  fileName        String?  @map("file_name")
  // Cached preview thumb file_id, when available. Used for picker UI.
  thumbFileId     String?  @map("thumb_file_id")
  // Where it came from. 'inbound' = admin sent it to the bot. 'upload' =
  // uploaded directly through the admin panel and then echoed back via
  // sendDocument-self to get a file_id (deferred to future iter).
  source          String   @default("inbound")
  // Telegram chat_id of the admin who captured it — for audit.
  capturedByChatId String? @map("captured_by_chat_id")
  createdAt       DateTime @default(now()) @map("created_at")
  lastUsedAt      DateTime? @map("last_used_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, kind, createdAt])
  @@index([botId, fileUniqueId])
  @@map("tg_media_files")
}
