generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserTariff {
  VR // Vostrebovannyi
  LR // Lider Rynka
  SR // Samostoyatelnyi
}

model User {
  id                      String                  @id @default(uuid())
  email                   String                  @unique
  passwordHash            String                  @map("password_hash")
  fullName                String?                 @map("full_name")
  avatarUrl               String?                 @map("avatar_url")
  role                    UserRole                @default(student)
  tariff                  UserTariff?             @map("tariff")
  sessionId               String?                 @map("session_id")
  isBlocked               Boolean                 @default(false) @map("is_blocked")
  frozenUntil             DateTime?               @map("frozen_until")
  emailVerified           Boolean                 @default(false) @map("email_verified")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  passwordResetExpires    DateTime?               @map("password_reset_expires")
  passwordResetToken      String?                 @map("password_reset_token")
  about                   String?
  phone                   String?
  telegram                String?
  track                   String?
  lastActiveAt            DateTime?               @map("last_active_at")
  auditLogs               AuditLog[]
  courses                 Course[]                @relation("CourseAuthor")
  enrollments             Enrollment[]
  groupMembers            GroupMember[]
  reviewedHomeworkHistory HomeworkHistory[]       @relation("HomeworkHistoryReviewer")
  reviewedHomework        HomeworkSubmission[]    @relation("HomeworkReviewer")
  homework                HomeworkSubmission[]
  lessonComments          LessonComment[]
  progress                LessonProgress[]
  uploadedMedia           MediaFile[]             @relation("MediaUploader")
  notificationPreference  NotificationPreference?
  notifications           Notification[]
  reviewedQuizzes         QuizAttempt[]           @relation("QuizReviewer")
  quizAttempts            QuizAttempt[]
  twoFactorAuth           TwoFactorAuth?
  userSessions            UserSession[]
  errorLogs               ErrorLog[]
  loginTokens             LoginToken[]
  keywords                String[]                @default([])  // Накопленные ключевые слова из форм
  certificates            Certificate[]
  orders                  Order[]
  messagingBots           MessagingBot[]
  messagingSubscribers    MessagingSubscriber[]
  broadcastsCreated       Broadcast[]             @relation("BroadcastAuthor")
  broadcastsReceived      BroadcastRecipient[]    @relation("BroadcastRecipientUser")
  questionsAsked          Question[]              @relation("QuestionStudent")
  questionsAssigned       Question[]              @relation("QuestionCurator")
  questionMessages        QuestionMessage[]
  brief                   Brief?
  tgSubscribers           TgSubscriber[]

  @@index([email])
  @@map("users")
}

model LoginToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("login_tokens")
}

model Course {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  description String?
  coverImage  String?      @map("cover_image")
  isPublished Boolean      @default(false) @map("is_published")
  authorId    String       @map("author_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  autoIssueCertificate Boolean @default(false) @map("auto_issue_certificate")
  certificateTemplateId String? @map("certificate_template_id")
  author      User         @relation("CourseAuthor", fields: [authorId], references: [id])
  enrollments Enrollment[]
  groups      Group[]
  modules     Module[]
  certificateTemplates CertificateTemplate[]
  certificates Certificate[]

  @@index([slug])
  @@index([authorId])
  @@map("courses")
}

model Module {
  id             String       @id @default(uuid())
  courseId       String       @map("course_id")
  parentId       String?      @map("parent_id")
  title          String
  orderIndex     Int          @map("order_index")
  allowedTariffs UserTariff[] @map("allowed_tariffs")
  allowedTracks  String[]     @map("allowed_tracks")
  allowedGroups  String[]     @map("allowed_groups")
  openAt         DateTime?    @map("open_at")
  openAfterAmount Int?        @map("open_after_amount")
  openAfterUnit  String?      @map("open_after_unit") // 'days', 'weeks'
  openAfterEvent String?      @map("open_after_event") // 'track_definition'
  trackSettings  Json?        @map("track_settings")
  groupSettings  Json?        @map("group_settings")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  lessons        Lesson[]
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parent         Module?      @relation("ModuleHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Module[]     @relation("ModuleHierarchy")

  @@index([courseId])
  @@index([parentId])
  @@map("modules")
}

model Lesson {
  id                 String               @id @default(uuid())
  moduleId           String               @map("module_id")
  title              String
  type               LessonType
  content            Json?
  videoId            String?              @map("video_id")
  videoDuration      Int?                 @map("video_duration")
  thumbnailUrl       String?              @map("thumbnail_url")
  isFree             Boolean              @default(false) @map("is_free")
  isStopLesson       Boolean              @default(false) @map("is_stop_lesson")
  dripRule           Json?                @map("drip_rule")
  settings           Json?
  orderIndex         Int                  @map("order_index")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  quizMaxAttempts    Int?                 @default(3) @map("quiz_max_attempts")
  quizPassingScore   Int?                 @map("quiz_passing_score")
  quizRequiresReview Boolean              @default(false) @map("quiz_requires_review")
  quizTimeLimit      Int?                 @map("quiz_time_limit")
  aiPrompt           String?              @db.Text @map("ai_prompt")
  aiContext          String?              @db.Text @map("ai_context")
  autoResponse       String?              @db.Text @map("auto_response")
  hasImageAnalysis   Boolean              @default(false) @map("has_image_analysis")
  homework           HomeworkSubmission[]
  comments           LessonComment[]
  LessonMedia        LessonMedia[]
  progress           LessonProgress[]
  module             Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizAttempts       QuizAttempt[]
  landingBlocks      LandingBlock[]

  @@index([moduleId])
  @@map("lessons")
}

model Enrollment {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  courseId          String           @map("course_id")
  status            EnrollmentStatus @default(active)
  startDate         DateTime         @map("start_date")
  expiresAt         DateTime?        @map("expires_at")
  restrictedModules String[]         @default([]) @map("restricted_modules")
  forcedModules     String[]         @default([]) @map("forced_modules")
  restrictedLessons String[]         @default([]) @map("restricted_lessons")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  course            Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  courseId    String?       @map("course_id")
  startDate   DateTime?     @map("start_date")
  members     GroupMember[]
  course      Course?       @relation(fields: [courseId], references: [id])

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model LessonProgress {
  userId      String         @map("user_id")
  lessonId    String         @map("lesson_id")
  status      ProgressStatus @default(not_started)
  watchedTime Int            @default(0) @map("watched_time")
  completedAt DateTime?      @map("completed_at")
  lastUpdated DateTime       @default(now()) @updatedAt @map("last_updated")
  rating      Int?           @map("rating")
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model HomeworkSubmission {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  lessonId       String?           @map("lesson_id")
  landingBlockId String?           @map("landing_block_id")
  content        String?
  files          Json?
  curatorFiles   Json?             @map("curator_files")
  status         HomeworkStatus    @default(pending)
  curatorComment String?            @map("curator_comment")
  curatorAudioUrl String?           @map("curator_audio_url")
  curatorId      String?            @map("curator_id")
  reviewedAt     DateTime?         @map("reviewed_at")
  
  // Auto-Review fields
  autoResponseScheduledAt DateTime? @map("auto_response_scheduled_at")
  responseTemplateIndex   Int?      @map("response_template_index")

  // AI-анализ от Джарвикса — виден только куратору/админу, студенту не отправляется.
  // aiAnalysisStartedAt / aiAnalysisError — состояние async-обработки:
  //  startedAt set, analyzedAt null, error null  → в процессе (polling)
  //  analyzedAt set                              → готово
  //  error set                                   → провалилось, можно перезапустить
  aiSuggestedVerdict   String?   @map("ai_suggested_verdict")
  aiSuggestedComment   String?   @map("ai_suggested_comment") @db.Text
  aiAnalyzedAt         DateTime? @map("ai_analyzed_at")
  aiAnalysisStartedAt  DateTime? @map("ai_analysis_started_at")
  aiAnalysisError      String?   @map("ai_analysis_error") @db.Text
  
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  history        HomeworkHistory[]
  curator        User?             @relation("HomeworkReviewer", fields: [curatorId], references: [id])
  lesson         Lesson?           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  landingBlock   LandingBlock?     @relation(fields: [landingBlockId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@index([landingBlockId])
  @@index([status])
  @@map("homework_submissions")
}

model HomeworkHistory {
  id             String             @id @default(uuid())
  submissionId   String             @map("submission_id")
  content        String?
  files          Json?
  status         HomeworkStatus
  curatorComment String?            @map("curator_comment")
  curatorAudioUrl String?           @map("curator_audio_url")
  curatorId      String?            @map("curator_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  curator        User?              @relation("HomeworkHistoryReviewer", fields: [curatorId], references: [id])
  submission     HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([createdAt])
  @@map("homework_history")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  link      String?  @map("link")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model QuizAttempt {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  lessonId       String    @map("lesson_id")
  attemptNumber  Int       @map("attempt_number")
  answers        Json
  score          Int?
  isPassed       Boolean   @default(false) @map("is_passed")
  isAutoGraded   Boolean   @default(false) @map("is_auto_graded")
  requiresReview Boolean   @default(false) @map("requires_review")
  curatorComment String?   @map("curator_comment")
  curatorId      String?   @map("curator_id")
  startedAt      DateTime  @default(now()) @map("started_at")
  submittedAt    DateTime? @map("submitted_at")
  timeSpent      Int?      @map("time_spent")
  curator        User?     @relation("QuizReviewer", fields: [curatorId], references: [id])
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([lessonId])
  @@index([isPassed])
  @@map("quiz_attempts")
}

model MediaFile {
  id               String        @id @default(uuid())
  name             String
  originalName     String        @map("original_name")
  mimeType         String        @map("mime_type")
  size             Int
  url              String
  signedUrl        String?       @map("signed_url")
  signedUrlExpires DateTime?     @map("signed_url_expires")
  uploadedById     String        @map("uploaded_by_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  lessonMedia      LessonMedia[]
  uploadedBy       User          @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([mimeType])
  @@map("media_files")
}

model LessonMedia {
  id         String    @id @default(uuid())
  lessonId   String    @map("lesson_id")
  mediaId    String    @map("media_id")
  orderIndex Int       @default(0) @map("order_index")
  createdAt  DateTime  @default(now()) @map("created_at")
  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  media      MediaFile @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([lessonId, mediaId])
  @@index([lessonId])
  @@map("lesson_media")
}

model LessonComment {
  id        String          @id @default(uuid())
  lessonId  String          @map("lesson_id")
  userId    String          @map("user_id")
  parentId  String?         @map("parent_id")
  content   String
  isDeleted Boolean         @default(false) @map("is_deleted")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent    LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   LessonComment[] @relation("CommentReplies")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
  @@index([parentId])
  @@map("lesson_comments")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  channels    Json
  preferences Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model UserSession {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  sessionId      String   @map("session_id")
  deviceName     String?  @map("device_name")
  deviceType     String?  @map("device_type")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  isActive       Boolean  @default(true) @map("is_active")
  lastActivityAt DateTime @default(now()) @updatedAt @map("last_activity_at")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([userId])
  @@index([isActive])
  @@map("user_sessions")
}

model TwoFactorAuth {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  secret      String
  isEnabled   Boolean  @default(false) @map("is_enabled")
  backupCodes String[] @map("backup_codes")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_auth")
}

enum TwoFactorMethod {
  totp
  sms
  email

  @@map("two_factor_method")
}

model ErrorLog {
  id          String        @id @default(uuid())
  groupId     String?       @map("group_id")
  message     String
  stack       String?       @db.Text
  url         String?
  userAgent   String?       @map("user_agent")
  userId      String?       @map("user_id")
  sessionId   String?       @map("session_id")
  severity    ErrorSeverity @default(error)
  status      ErrorStatus   @default(new)
  metadata    Json?
  browserInfo Json?         @map("browser_info")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  group ErrorGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([userId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("error_logs")
}

model ErrorGroup {
  id            String        @id @default(uuid())
  fingerprint   String        @unique
  title         String
  message       String
  count         Int           @default(1)
  status        ErrorStatus   @default(new)
  severity      ErrorSeverity @default(error)
  firstOccurred DateTime      @default(now()) @map("first_occurred")
  lastOccurred  DateTime      @default(now()) @map("last_occurred")
  resolvedAt    DateTime?     @map("resolved_at")
  resolvedBy    String?       @map("resolved_by")
  notes         String?       @db.Text

  errors ErrorLog[]

  @@index([fingerprint])
  @@index([status])
  @@index([lastOccurred])
  @@map("error_groups")
}

enum ErrorSeverity {
  critical
  error
  warning
  info

  @@map("error_severity")
}

enum ErrorStatus {
  new
  investigating
  resolved
  ignored

  @@map("error_status")
}

enum UserRole {
  student
  admin
  curator
}

enum LessonType {
  video
  text
  quiz
  track_definition
  intermediate_survey
  certification_form
}

enum EnrollmentStatus {
  active
  expired
  frozen
}

enum ProgressStatus {
  not_started
  in_progress
  completed
  failed
}

enum HomeworkStatus {
  pending
  approved
  rejected
}

model VideoLibrary {
  id           String   @id @default(uuid())
  title        String
  cloudflareId String   @unique @map("cloudflare_id")
  duration     Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("video_library")
}

model LandingPage {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  isPublished Boolean        @default(false) @map("is_published")
  views       Int            @default(0)
  settings    Json?          // Stores Bitrix integration and other page-specific settings
  blocks      LandingBlock[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("landing_pages")
}

model LandingBlock {
  id                String               @id @default(uuid())
  pageId            String               @map("page_id")
  type              String               // 'text', 'form', 'video'
  content           Json
  design            Json?                // Background, text color, padding, etc.
  settings          Json?                // UTM tags, openAt
  responseTemplates String[]             @default([]) @map("response_templates")
  orderIndex        Int                  @map("order_index")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  lessonId          String?              @map("lesson_id")
  lesson            Lesson?              @relation(fields: [lessonId], references: [id])
  page              LandingPage          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  submissions       HomeworkSubmission[]

  @@index([pageId])
  @@index([lessonId])
  @@map("landing_blocks")
}

model CertificateTemplate {
  id              String   @id @default(uuid())
  courseId        String?  @map("course_id")
  name            String
  imageUrl        String   @map("image_url")
  fieldConfig     Json     @map("field_config")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  course          Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificates    Certificate[]
  
  @@index([courseId])
  @@map("certificate_templates")
}

model Certificate {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  courseId            String   @map("course_id")
  templateId          String   @map("template_id")
  certificateNumber   String   @unique @map("certificate_number")
  pdfUrl              String   @map("pdf_url")
  issuedAt            DateTime @default(now()) @map("issued_at")
  
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course              Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  template            CertificateTemplate @relation(fields: [templateId], references: [id])
  
  @@index([userId])
  @@index([courseId])
  @@index([certificateNumber])
  @@map("certificates")
}

// ─── Payments ────────────────────────────────────────────────────────────────

enum OrderStatus {
  pending             // создан, ждёт оплаты
  waiting_for_capture // холд (pre-auth), ожидает подтверждения
  paid                // оплачен
  cancelled           // отменён (пользователем или просрочен)
  refunded            // возврат
}

/// Торговое предложение — то, что продаётся (курс, тариф, пакет).
model Offer {
  id          String      @id @default(uuid())
  title       String
  description String?     @db.Text
  price       Decimal     @db.Decimal(10, 2)
  oldPrice    Decimal?    @db.Decimal(10, 2) @map("old_price")
  currency    String      @default("RUB")
  isActive    Boolean     @default(true) @map("is_active")
  /// Сколько дней доступ к курсам (null = бессрочно)
  accessDays  Int?        @map("access_days")
  /// IDs курсов, которые открываются при покупке
  courseIds   String[]    @default([]) @map("course_ids")
  /// Тариф, который присваивается пользователю при покупке
  tariff      UserTariff?
  /// Описание того, что входит в оффер (маркированный список)
  features    String[]    @default([])
  /// Порядок отображения
  sortOrder   Int         @default(0) @map("sort_order")
  orders      Order[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("offers")
}

/// Заказ — запись о платеже пользователя за оффер.
model Order {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  offerId            String      @map("offer_id")
  amount             Decimal     @db.Decimal(10, 2)
  currency           String      @default("RUB")
  status             OrderStatus @default(pending)
  /// ID платежа в ЮКассе
  ykPaymentId        String?     @unique @map("yk_payment_id")
  /// URL для редиректа на оплату (одноразовый, 1 час жизни)
  ykConfirmationUrl  String?     @db.Text @map("yk_confirmation_url")
  /// Метод оплаты, выбранный пользователем (bank_card, sbp, installments, …)
  paymentMethod      String?     @map("payment_method")
  /// Сырой объект платежа из ЮКассы (последний известный)
  ykSnapshot         Json?       @map("yk_snapshot")
  paidAt             DateTime?   @map("paid_at")
  /// Токен для публичной ссылки оплаты. Заказы созданные админом для
  /// клиента имеют этот токен — клиент открывает /pay/[orderId]?token=...
  /// и оплачивает без логина в LMS.
  paymentLinkToken   String?     @unique @map("payment_link_token")
  /// Кто создал заказ (админ при ручном создании). null = клиент сам.
  createdByAdminId   String?     @map("created_by_admin_id")
  /// Когда был сделан возврат (полный или частичный)
  refundedAt         DateTime?   @map("refunded_at")
  /// Причина возврата (от админа), для аудита
  refundReason       String?     @db.Text @map("refund_reason")
  /// Сумма возврата. Если null или равна amount — полный. Иначе частичный.
  refundedAmount     Decimal?    @db.Decimal(10, 2) @map("refunded_amount")
  /// Снапшот состава оффера на момент создания заказа.
  /// Используется при активации, чтобы изменения оффера не меняли уже оплаченное.
  snapshotCourseIds  String[]    @default([]) @map("snapshot_course_ids")
  snapshotTariff     UserTariff? @map("snapshot_tariff")
  snapshotAccessDays Int?        @map("snapshot_access_days")
  snapshotOfferTitle String?     @map("snapshot_offer_title")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([ykPaymentId])
  @@map("orders")
}

/// Singleton настройки платёжного модуля (чеки 54-ФЗ + restricted methods).
/// Хранится одна строка с фиксированным id = "default". Если БД-настроек
/// нет — провайдер берёт значения из env (CP_RECEIPT_*).
model PaymentSettings {
  id                String   @id @default("default")
  /// Включить передачу чека 54-ФЗ в виджет CloudPayments
  receiptEnabled    Boolean  @default(true) @map("receipt_enabled")
  /// Система налогообложения:
  /// 0=ОСН, 1=УСН доходы, 2=УСН доходы-расходы, 3=ЕНВД, 4=ЕСН, 5=Патент
  taxationSystem    Int      @default(1) @map("taxation_system")
  /// НДС: 0=без НДС, 10=10%, 20=20%
  vat               Int      @default(0)
  /// Признак способа расчёта: 1=предоплата 100%, 2=предоплата, 3=аванс,
  /// 4=полный расчёт, 5=частичный расчёт и кредит, …
  method            Int      @default(4)
  /// Признак предмета расчёта: 1=товар, 2=подакцизный, 3=работа, 4=услуга, …
  object            Int      @default(4)
  /// Comma-separated методы оплаты которые скрыть в виджете
  /// (Card,ForeignCard,Sbp,Dolyame,TcsInstallment,TinkoffPay,SberPay,MirPay)
  restrictedMethods String[] @default([]) @map("restricted_methods")
  /// Single или Dual схема (одностадийная / с холдом)
  paymentSchema     String   @default("Single") @map("payment_schema")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedById       String?  @map("updated_by_id")

  @@map("payment_settings")
}

model Broadcast {
  id          String   @id @default(uuid())
  authorId    String   @map("author_id")
  title       String
  message     String   @db.Text
  channels    String[] // ['lms', 'email']
  targets     Json     // { roles, groupIds, tariffs, tracks }
  recipients  Int      @default(0)
  sentCount   Int      @default(0) @map("sent_count")
  failedCount Int      @default(0) @map("failed_count")
  status      String   @default("pending") // pending, sending, completed, failed
  sentAt      DateTime @default(now()) @map("sent_at")
  author      User                 @relation("BroadcastAuthor", fields: [authorId], references: [id])
  recipientLogs BroadcastRecipient[]

  @@index([authorId])
  @@index([sentAt])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id          String    @id @default(uuid())
  broadcastId String    @map("broadcast_id")
  userId      String    @map("user_id")
  email       String?
  lmsStatus   String?   @map("lms_status")   // sent | failed | skipped
  emailStatus String?   @map("email_status") // sent | failed | skipped
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at")
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user        User      @relation("BroadcastRecipientUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([userId])
  @@map("broadcast_recipients")
}

enum QuestionStatus {
  open
  in_progress
  answered
  closed

  @@map("question_status")
}

model Question {
  id              String            @id @default(uuid())
  studentId       String            @map("student_id")
  curatorId       String?           @map("curator_id")
  subject         String
  lessonId        String?           @map("lesson_id")
  status          QuestionStatus    @default(open)
  rating          Int?
  ratingComment   String?           @map("rating_comment") @db.Text
  firstResponseAt   DateTime?         @map("first_response_at")
  closedAt          DateTime?         @map("closed_at")
  lastMentorCallAt  DateTime?         @map("last_mentor_call_at")
  jarvisRepliedAt   DateTime?         @map("jarvis_replied_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  student         User              @relation("QuestionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  curator         User?             @relation("QuestionCurator", fields: [curatorId], references: [id])
  messages        QuestionMessage[]

  @@index([studentId])
  @@index([curatorId])
  @@index([status])
  @@index([createdAt])
  @@map("questions")
}

model QuestionMessage {
  id           String    @id @default(uuid())
  questionId   String    @map("question_id")
  authorId     String?   @map("author_id")
  content      String    @db.Text
  attachments  Json?
  readAt       DateTime? @map("read_at")
  isAiReply    Boolean   @default(false) @map("is_ai_reply")
  aiSenderName String?   @map("ai_sender_name")
  createdAt    DateTime  @default(now()) @map("created_at")
  question     Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  author       User?     @relation(fields: [authorId], references: [id])

  @@index([questionId, createdAt])
  @@index([authorId])
  @@map("question_messages")
}

model EmailTemplate {
  id          String   @id @default(uuid())
  event       String
  name        String
  subject     String
  body        String   @db.Text
  variables   Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

// =================================================================
// Bot platform (Telegram-first SaleBot/BotHelp replacement)
// All tables are isolated under tg_* prefix and do not touch
// the existing LMS schema. Single-tenant for now: the school IS
// the only org. Multi-tenant can be added later via orgId.
// =================================================================

model TgBot {
  id              String   @id @default(uuid())
  // Encrypted Telegram bot token. NEVER store the raw token.
  // Encryption: AES-256-GCM, see lib/tg/crypto.ts
  tokenEncrypted  String   @map("token_encrypted") @db.Text
  // First 8 chars of the token (before ':'), kept for display only.
  tokenPrefix     String   @map("token_prefix")
  // Bot identity from getMe.
  botUserId       String   @unique @map("bot_user_id")
  username        String
  title           String
  // Random secret token used to verify Telegram webhook calls
  // (X-Telegram-Bot-Api-Secret-Token header).
  webhookSecret   String   @map("webhook_secret")
  webhookUrl      String?  @map("webhook_url")
  isActive        Boolean  @default(true) @map("is_active")
  // Default flow triggered by /start without payload (optional).
  defaultStartFlowId String? @map("default_start_flow_id")
  // Bot-wide variables ("project.x") and constants. Editable in admin.
  // Both are {key: value} JSON objects. Used by the expression engine
  // when a template references `{{project.x}}` or `{{const.x}}`.
  projectVariables Json    @default("{}") @map("project_variables")
  constants       Json     @default("{}")
  // IANA tz; used by date helpers (current_date, weekday, etc.).
  // null = UTC. Default Moscow.
  timezone        String?  @default("Europe/Moscow")
  // Telegram chat_ids of admins whose inbound media is auto-captured
  // into the media library. Empty list = no auto-capture. Set this on
  // bot creation in the admin UI.
  adminChatIds    String[] @default([]) @map("admin_chat_ids")
  // Aggregate stats kept in sync by tg core for fast dashboards.
  subscriberCount Int      @default(0) @map("subscriber_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  subscribers     TgSubscriber[]
  messages        TgMessage[]
  flows           TgFlow[]
  broadcasts      TgBroadcast[]
  trackingLinks   TgTrackingLink[]
  events          TgEvent[]
  mediaFiles      TgMediaFile[]
  lists           TgList[]
  customFields    TgCustomField[]
  redirectLinks   TgRedirectLink[]
  scheduledFlows  TgScheduledFlow[]
  bitrixConfig    TgBitrixConfig?

  @@index([username])
  @@map("tg_bots")
}

// Per-bot Bitrix24 integration configuration.
// Stores webhook URL override, field mappings, and tag triggers.
// One-to-one with TgBot (optional — not every bot needs CRM sync).
model TgBitrixConfig {
  id              String   @id @default(uuid())
  botId           String   @unique @map("bot_id")
  // Whether sync is active. False = all sync calls are no-ops.
  enabled         Boolean  @default(false)
  // Per-bot webhook override. If null, falls back to env BITRIX24_WEBHOOK_URL.
  webhookUrl      String?  @map("webhook_url") @db.Text
  // Target funnel (deal category). "0" = default Bitrix funnel.
  funnelId        String   @default("0") @map("funnel_id")
  // Default stage ID for newly created deals (e.g. "C14:NEW").
  // Empty = Bitrix picks the first stage.
  defaultStageId  String   @default("") @map("default_stage_id")
  // Contact field mappings: [{lmsVar: "client.phone", bitrixField: "PHONE"}]
  // lmsVar supports: client.*, custom.*, deal.* (from run context)
  contactMappings Json     @default("[]") @map("contact_mappings")
  // Deal field mappings: [{lmsVar: "client.utm_source", bitrixField: "UTM_SOURCE"}]
  dealMappings    Json     @default("[]") @map("deal_mappings")
  // Tag triggers: [{tag: "квалифицирован", stageId: "C14:PREPAYMENT_INVOIC"}]
  // When subscriber gets this tag (via flow or inline action) →
  // syncSubscriberToBitrix is called automatically with this stageId.
  tagTriggers     Json     @default("[]") @map("tag_triggers")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("tg_bitrix_configs")
}

model TgSubscriber {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Telegram numeric IDs come as int64; we store as string for safety.
  chatId          String   @map("chat_id")
  tgUserId        String   @map("tg_user_id")
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  username        String?
  languageCode    String?  @map("language_code")
  // Set true if Telegram returns 403 (user blocked the bot).
  isBlocked       Boolean  @default(false) @map("is_blocked")
  // Free-form tags. Single-tenant per-bot — keep it simple.
  tags            String[] @default([])
  // Arbitrary key/value variables set by flow nodes or API.
  variables       Json     @default("{}")
  // First/last touch attribution.
  firstTouchSlug  String?  @map("first_touch_slug")
  firstTouchAt    DateTime? @map("first_touch_at")
  lastTouchSlug   String?  @map("last_touch_slug")
  lastTouchAt     DateTime? @map("last_touch_at")
  lastSeenAt      DateTime? @map("last_seen_at")
  subscribedAt    DateTime @default(now()) @map("subscribed_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")

  // -- Position in funnel (SaleBot "позиция воронки") -------------------
  // The latest Step (positional message-node) the subscriber walked into.
  // Used to:
  //   1. Display where the subscriber currently is in any funnel
  //   2. Auto-cancel side-effect/dozhim runs originating from a previous
  //      position when the subscriber moves to a new one.
  // null = subscriber has never reached a positional node.
  currentPositionFlowId String? @map("current_position_flow_id")
  currentPositionNodeId String? @map("current_position_node_id")
  currentPositionAt     DateTime? @map("current_position_at")

  // List of "flowId:nodeId" pairs whose triggers fired with onlyOnce=true.
  // Prevents re-entry. Empty in practice for most subscribers.
  firedOnceTriggers     String[] @default([]) @map("fired_once_triggers")

  // -- Operator live-chat takeover --------------------------------------
  // Когда оператор берёт диалог «в ручной режим», auto-trigger’ы флоу и
  // delivery в wait_reply отключаются: бот не перебивает живого человека.
  // takeoverAt — момент, когда взяли в работу. Авто-release через 24ч,
  // чтобы случайно не оставить чат заблокированным навсегда.
  operatorTakeoverAt    DateTime? @map("operator_takeover_at")
  operatorAssigneeId    String?   @map("operator_assignee_id")

  // Typed custom fields ("доп. поля" in SaleBot terms). Stored as
  // {key: value} with schema defined at the bot level (TgCustomField,
  // added in Iter 2). For Iter 1 this is just a free-form JSON bag —
  // wait_reply nodes can save into it via `saveAs: "field.<key>"`.
  customFields    Json     @default("{}") @map("custom_fields")

  // Link to LMS User resolved by email/phone match.
  // Set automatically when a subscriber provides their email or phone
  // in a flow, or when a landing form is submitted with matching email.
  lmsUserId       String?   @map("lms_user_id")
  lmsUser         User?     @relation(fields: [lmsUserId], references: [id], onDelete: SetNull)

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages        TgMessage[]
  flowRuns        TgFlowRun[]
  events          TgEvent[]
  broadcastDeliveries TgBroadcastRecipient[]
  lists           TgSubscriberList[]

  @@unique([botId, chatId])
  @@index([botId, isBlocked])
  @@index([botId, lastSeenAt])
  @@index([botId, currentPositionFlowId, currentPositionNodeId])
  @@index([botId, operatorTakeoverAt])
  @@index([tags], type: Gin)
  @@index([lmsUserId])
  @@map("tg_subscribers")
}

// ─── Channel-agnostic messaging (Instagram, MAX, future channels) ──────────
//
// Параллельная Tg*-моделям инфраструктура для каналов, не использующих
// Bot API в стиле Telegram. Telegram пока живёт в TgBot/TgSubscriber и
// будет смержен сюда позже (Фаза 1/2 из roadmap).

enum MessagingChannel {
  telegram
  instagram
  max
}

/// Универсальный «бот» для любого канала.
/// externalAccountId — IG user_id, MAX bot_id, и т.д.
model MessagingBot {
  id                String           @id @default(uuid())
  channel           MessagingChannel
  /// ID аккаунта на стороне платформы (IG user_id / MAX user_id / TG bot_id)
  externalAccountId String           @map("external_account_id")
  /// Отображаемое имя (IG username, @MAX-handle, etc.)
  title             String
  /// Зашифрованный access token (long-lived для IG, бот-токен для MAX)
  tokenEnc          String           @db.Text @map("token_enc")
  /// Когда token истекает (для каналов с refresh — IG: 60 дней)
  tokenExpiresAt    DateTime?        @map("token_expires_at")
  /// Доп. атрибуты канала: account_type, scopes, и т.д.
  meta              Json?
  isActive          Boolean          @default(true) @map("is_active")
  /// Кто подключил аккаунт. Используется для прав доступа.
  ownerId           String           @map("owner_id")
  owner             User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  subscribers       MessagingSubscriber[]
  flows             MessagingFlow[]
  messages          MessagingMessage[]
  broadcasts        MessagingBroadcast[]
  lists             MessagingList[]
  customFields      MessagingCustomField[]
  events            MessagingEvent[]
  auditLogs         MessagingBotAuditLog[]
  bitrixConfig      MessagingBitrixConfig?
  trackingLinks     MessagingTrackingLink[]

  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@unique([channel, externalAccountId])
  @@index([ownerId])
  @@map("messaging_bots")
}

/// Подписчик на стороне канала. externalUserId — IGSID для Instagram,
/// chat_id для МАКС/Telegram.
model MessagingSubscriber {
  id             String       @id @default(uuid())
  botId          String       @map("bot_id")
  bot            MessagingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  externalUserId String       @map("external_user_id")
  firstName      String?      @map("first_name")
  lastName       String?      @map("last_name")
  username       String?
  variables      Json         @default("{}")
  tags           String[]     @default([])
  /// Время последнего входящего — для проверки 24h messaging window (IG)
  lastInboundAt  DateTime?    @map("last_inbound_at")
  subscribedAt   DateTime     @default(now()) @map("subscribed_at")
  lastSeenAt     DateTime?    @map("last_seen_at")
  /// Связь с пользователем LMS (если матчится по email/телефону позже)
  lmsUserId      String?      @map("lms_user_id")
  lmsUser        User?        @relation(fields: [lmsUserId], references: [id], onDelete: SetNull)
  /// Когда оператор взял диалог под ручное управление.
  /// Пока set — auto-triggers и flow-engine для этого подписчика выключены.
  operatorTakeoverAt   DateTime? @map("operator_takeover_at")
  /// Кто из админов ведёт диалог (для маршрутизации inbox)
  operatorAssigneeId   String?   @map("operator_assignee_id")
  flowRuns       MessagingFlowRun[]
  messages       MessagingMessage[]
  broadcastReceipts MessagingBroadcastRecipient[]
  listMembers    MessagingListMember[]

  @@unique([botId, externalUserId])
  @@index([botId])
  @@index([lmsUserId])
  @@index([operatorAssigneeId])
  @@map("messaging_subscribers")
}

/// Временный CSRF-state для OAuth-сессий подключения каналов.
/// TTL ~10 минут. Очищается фоновым cron.
model MessagingOAuthState {
  id          String           @id @default(uuid())
  state       String           @unique
  channel     MessagingChannel
  /// Кто инициировал подключение
  userId      String           @map("user_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  expiresAt   DateTime         @map("expires_at")

  @@index([expiresAt])
  @@map("messaging_oauth_states")
}

// ─── Channel-agnostic flow infrastructure ──────────────────────────────────
//
// Универсальная инфраструктура воронок (flows) для MessagingBot.
// Работает поверх любого канала через BotProvider абстракцию.

enum MessagingTriggerType {
  /// Запуск по ключевому слову в DM (Instagram + МАКС + любой канал с DM)
  keyword_dm
  /// Запуск по ключевому слову в комментарии к посту (Instagram)
  keyword_comment
  /// Запуск по ответу на сторис (Instagram)
  story_reply
  /// Запуск по упоминанию в сторис/посте (Instagram)
  mention
  /// Запуск при первом контакте подписчика
  subscriber_joined
  /// Ручной запуск через API/UI
  manual
}

enum MessagingFlowRunStatus {
  running          // активный, исполняется узел
  waiting_reply    // ждём ответа подписчика
  completed        // дошёл до end-узла
  cancelled        // прерван (новый flow запущен, пользователь заблокирован, etc.)
  failed           // упал с ошибкой (см. lastError)
}

/// Воронка. graph — JSON со схемой узлов и переходов:
///   {
///     "startNodeId": "n1",
///     "nodes": {
///       "n1": { "type": "send_text", "text": "Привет!", "next": "n2" },
///       "n2": { "type": "wait_reply", "timeoutSec": 86400, "onReply": "n3", "onTimeout": "n4" },
///       "n3": { "type": "condition", "match": { "keyword": "цена" }, "onMatch": "n4", "onNoMatch": "n5" },
///       "n4": { "type": "send_quick_replies", "text": "Выбери:", "buttons": [{"title":"A","payload":"a"}], "next": "n6" },
///       "n5": { "type": "end" }
///     }
///   }
model MessagingFlow {
  id         String   @id @default(uuid())
  botId      String   @map("bot_id")
  bot        MessagingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  name       String
  description String? @db.Text
  isActive   Boolean  @default(true) @map("is_active")
  graph      Json
  /// Счётчик запусков (для аналитики)
  runCount   Int      @default(0) @map("run_count")
  triggers   MessagingTrigger[]
  runs       MessagingFlowRun[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([botId])
  @@map("messaging_flows")
}

/// Триггер запуска воронки. Один flow может иметь несколько триггеров
/// (разные ключевые слова, разные типы — DM + комменты + сторис).
model MessagingTrigger {
  id              String               @id @default(uuid())
  flowId          String               @map("flow_id")
  flow            MessagingFlow        @relation(fields: [flowId], references: [id], onDelete: Cascade)
  type            MessagingTriggerType
  /// Ключевые слова (для keyword_*, story_reply типов). Пусто = любой триггер этого типа.
  keywords        String[]             @default([])
  /// Алгоритм матчинга: "exact" | "contains" | "regex" | "starts_with"
  matchType       String               @default("contains") @map("match_type")
  caseSensitive   Boolean              @default(false) @map("case_sensitive")
  /// Для keyword_comment / mention — ограничение по конкретному посту (media_id),
  /// пусто = на все посты.
  mediaIds        String[]             @default([]) @map("media_ids")
  /// Метрики
  triggerCount    Int                  @default(0) @map("trigger_count")
  lastTriggeredAt DateTime?            @map("last_triggered_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([flowId])
  @@index([type])
  @@map("messaging_triggers")
}

/// Instance запущенной воронки для конкретного подписчика.
model MessagingFlowRun {
  id            String                 @id @default(uuid())
  flowId        String                 @map("flow_id")
  flow          MessagingFlow          @relation(fields: [flowId], references: [id], onDelete: Cascade)
  subscriberId  String                 @map("subscriber_id")
  subscriber    MessagingSubscriber    @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  status        MessagingFlowRunStatus @default(running)
  /// Текущий узел графа (для возобновления)
  currentNodeId String?                @map("current_node_id")
  /// Контекст: накопленные переменные внутри воронки + последний ввод подписчика
  context       Json                   @default("{}")
  lastError     String?                @db.Text @map("last_error")
  /// Время до которого ждём ответ (для wait_reply timeout). Cron досрочно
  /// возобновит flow по веткам onTimeout.
  waitUntil     DateTime?              @map("wait_until")
  startedAt     DateTime               @default(now()) @map("started_at")
  completedAt   DateTime?              @map("completed_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  @@index([subscriberId])
  @@index([flowId, status])
  @@index([status, waitUntil])
  @@map("messaging_flow_runs")
}

// ─── Messaging: Inbox, Broadcasts, Lists, Custom Fields, Events ────────────

/// История сообщений: входящие и исходящие. Используется для Inbox UI.
model MessagingMessage {
  id                String              @id @default(uuid())
  botId             String              @map("bot_id")
  bot               MessagingBot        @relation(fields: [botId], references: [id], onDelete: Cascade)
  subscriberId     String              @map("subscriber_id")
  subscriber        MessagingSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  /// "in" = от подписчика к боту, "out" = от бота к подписчику
  direction        String
  text              String?             @db.Text
  /// Payload callback-кнопки (для in-сообщений когда пользователь нажал кнопку)
  callbackPayload  String?             @map("callback_payload")
  /// Сырые attachments как пришли/были отправлены — JSON
  attachments       Json?
  /// ID сообщения на стороне платформы (mid в MAX, message_id в TG)
  externalMessageId String?            @map("external_message_id")
  /// Источник для out: какая воронка / broadcast / takeover
  source           String?             // "flow:<flowId>" | "broadcast:<id>" | "operator:<userId>" | "trigger"
  createdAt        DateTime            @default(now()) @map("created_at")

  @@index([botId, subscriberId, createdAt])
  @@index([subscriberId, createdAt])
  @@index([botId, createdAt])
  @@map("messaging_messages")
}

enum MessagingBroadcastStatus {
  draft
  scheduled
  sending
  completed
  cancelled
  failed
}

/// Массовая рассылка по сегменту подписчиков.
model MessagingBroadcast {
  id              String                   @id @default(uuid())
  botId           String                   @map("bot_id")
  bot             MessagingBot             @relation(fields: [botId], references: [id], onDelete: Cascade)
  name            String
  /// Тело сообщения (текст с шаблонами)
  text            String                   @db.Text
  /// Опциональные кнопки в стиле send_buttons graph-узла
  buttons         Json?
  /// Фильтр аудитории: { tags: [], excludeTags: [], lists: [], excludeLists: [] }
  filter          Json                     @default("{}")
  status          MessagingBroadcastStatus @default(draft)
  /// Когда отправить (для scheduled). null = немедленно
  scheduledAt     DateTime?                @map("scheduled_at")
  /// Когда фактически стартовала отправка
  startedAt       DateTime?                @map("started_at")
  completedAt     DateTime?                @map("completed_at")
  /// Метрики
  totalRecipients Int                      @default(0) @map("total_recipients")
  sentCount       Int                      @default(0) @map("sent_count")
  failedCount     Int                      @default(0) @map("failed_count")
  lastError       String?                  @db.Text @map("last_error")
  createdById     String                   @map("created_by_id")
  recipients      MessagingBroadcastRecipient[]
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  @@index([botId, status])
  @@index([status, scheduledAt])
  @@map("messaging_broadcasts")
}

/// Запись о доставке одного broadcast одному подписчику.
model MessagingBroadcastRecipient {
  id            String              @id @default(uuid())
  broadcastId   String              @map("broadcast_id")
  broadcast     MessagingBroadcast  @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  subscriberId String              @map("subscriber_id")
  subscriber    MessagingSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  /// "pending" | "sent" | "failed" | "skipped"
  status        String              @default("pending")
  error         String?             @db.Text
  sentAt        DateTime?           @map("sent_at")

  @@unique([broadcastId, subscriberId])
  @@index([broadcastId, status])
  @@map("messaging_broadcast_recipients")
}

enum MessagingListType {
  /// Подписчики добавляются вручную или через flow-action
  static
  /// Подписчики автоматически добавляются по правилу (теги/поля)
  dynamic
}

/// Список подписчиков (сегмент). Используется для broadcasts и условий в flow.
model MessagingList {
  id          String            @id @default(uuid())
  botId       String            @map("bot_id")
  bot         MessagingBot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  name        String
  description String?           @db.Text
  type        MessagingListType @default(static)
  /// Для dynamic: { tags: ["vip"], excludeTags: [], anyOrAll: "all" }
  rules       Json?
  memberCount Int               @default(0) @map("member_count")
  members     MessagingListMember[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([botId])
  @@map("messaging_lists")
}

model MessagingListMember {
  id            String              @id @default(uuid())
  listId        String              @map("list_id")
  list          MessagingList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  subscriberId String              @map("subscriber_id")
  subscriber    MessagingSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  /// "manual" = добавлен вручную/действием, "auto" = по правилу dynamic-листа
  source        String              @default("manual")
  addedAt       DateTime            @default(now()) @map("added_at")

  @@unique([listId, subscriberId])
  @@index([subscriberId])
  @@map("messaging_list_members")
}

enum MessagingCustomFieldType {
  text
  number
  date
  email
  phone
  url
  bool
  select
}

/// Типизированное custom-поле подписчика. Значения хранятся в
/// MessagingSubscriber.variables под именем key.
model MessagingCustomField {
  id          String                   @id @default(uuid())
  botId       String                   @map("bot_id")
  bot         MessagingBot             @relation(fields: [botId], references: [id], onDelete: Cascade)
  /// Технический ключ — латиница/цифры/_, используется в variables и шаблонах
  key         String
  label       String
  type        MessagingCustomFieldType @default(text)
  /// Для select: список значений
  options     String[]                 @default([])
  required    Boolean                  @default(false)
  sortOrder   Int                      @default(0) @map("sort_order")
  createdAt   DateTime                 @default(now()) @map("created_at")

  @@unique([botId, key])
  @@index([botId])
  @@map("messaging_custom_fields")
}

/// Событие в системе для аналитики. Тип кодируется строкой
/// (SubscriberCreated, FlowStarted, FlowCompleted, BroadcastSent, и т.д.).
model MessagingEvent {
  id            String       @id @default(uuid())
  botId         String       @map("bot_id")
  bot           MessagingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  subscriberId String?      @map("subscriber_id")
  type          String
  /// Произвольные данные события (flowId, broadcastId, и т.п.)
  data          Json?
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([botId, type, createdAt])
  @@index([subscriberId, createdAt])
  @@map("messaging_events")
}

/// Аудит-лог админских операций над ботом (отдельно от LMS AuditLog).
model MessagingBotAuditLog {
  id          String       @id @default(uuid())
  botId       String       @map("bot_id")
  bot         MessagingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  actorUserId String       @map("actor_user_id")
  action      String
  entity      String?
  entityId    String?      @map("entity_id")
  details     Json?
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([botId, createdAt])
  @@map("messaging_bot_audit_logs")
}

/// Bitrix24-конфиг для messaging-бота (аналог TgBitrixConfig).
/// Поля совпадают с TgBitrixConfig по семантике: webhook, воронка,
/// маппинги контактов/сделок, tag-триггеры.
model MessagingBitrixConfig {
  id              String       @id @default(uuid())
  botId           String       @unique @map("bot_id")
  bot             MessagingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  enabled         Boolean      @default(false)
  webhookUrl      String?      @db.Text @map("webhook_url")
  funnelId        String       @default("0") @map("funnel_id")
  defaultStageId  String       @default("") @map("default_stage_id")
  contactMappings Json         @default("[]") @map("contact_mappings")
  dealMappings    Json         @default("[]") @map("deal_mappings")
  tagTriggers     Json         @default("[]") @map("tag_triggers")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("messaging_bitrix_configs")
}

/// Tracking-ссылки: короткий slug → редирект на target URL с
/// записью клика. Если subscriberId известен (передан как ?s= в slug-URL),
/// клик добавляется к атрибуции подписчика и эмитит event.
model MessagingTrackingLink {
  id          String       @id @default(uuid())
  botId       String       @map("bot_id")
  bot         MessagingBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  slug        String       @unique
  /// Целевой URL для редиректа
  targetUrl   String       @db.Text @map("target_url")
  /// Опциональный тег, который ставится подписчику при клике
  attachTag   String?      @map("attach_tag")
  /// Что-нибудь в context подписчика (например, lastClickedSlug)
  meta        Json?
  clickCount  Int          @default(0) @map("click_count")
  createdAt   DateTime     @default(now()) @map("created_at")

  clicks      MessagingTrackingClick[]

  @@index([botId])
  @@map("messaging_tracking_links")
}

/// Один клик по tracking-ссылке. Subscriber может быть пустым (анонимный клик).
model MessagingTrackingClick {
  id           String                @id @default(uuid())
  linkId       String                @map("link_id")
  link         MessagingTrackingLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  subscriberId String?               @map("subscriber_id")
  /// IP, ua и referer — best-effort, для дашборда.
  ip           String?
  userAgent    String?               @db.Text @map("user_agent")
  referer      String?               @db.Text
  createdAt    DateTime              @default(now()) @map("created_at")

  @@index([linkId, createdAt])
  @@index([subscriberId, createdAt])
  @@map("messaging_tracking_clicks")
}

model TgMessage {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  subscriberId    String   @map("subscriber_id")
  // 'in' = received from user, 'out' = sent by bot.
  direction       String
  // Telegram message_id from result (out) or update (in).
  tgMessageId     String?  @map("tg_message_id")
  // Raw text or caption.
  text            String?  @db.Text
  // For media: 'photo' | 'video' | 'document' | 'voice' | etc.
  mediaType       String?  @map("media_type")
  mediaFileId     String?  @map("media_file_id")
  // Inline-button payload if message is a callback_query result.
  callbackData    String?  @map("callback_data")
  // Source: flow run, broadcast, manual operator reply, inbound.
  sourceType      String?  @map("source_type")
  sourceId        String?  @map("source_id")
  // Raw Telegram payload (truncated) for diagnostics.
  rawPayload      Json?    @map("raw_payload")
  createdAt       DateTime @default(now()) @map("created_at")

  bot             TgBot         @relation(fields: [botId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([subscriberId, createdAt])
  @@map("tg_messages")
}

model TgFlow {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  name            String
  description     String?
  // Graph definition. See lib/tg/flow-schema.ts for the contract.
  // Shape: { nodes: TgFlowNode[], startNodeId: string, version: number }
  graph           Json
  isActive        Boolean  @default(true) @map("is_active")
  // Trigger config — array of trigger descriptors evaluated on
  // every inbound update. See lib/tg/flow-schema.ts.
  triggers        Json     @default("[]")
  // Aggregate stats updated by flow engine for fast dashboards.
  totalEntered    Int      @default(0) @map("total_entered")
  totalCompleted  Int      @default(0) @map("total_completed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  runs            TgFlowRun[]

  @@index([botId, isActive])
  @@map("tg_flows")
}

model TgFlowRun {
  id              String   @id @default(uuid())
  flowId          String   @map("flow_id")
  subscriberId    String   @map("subscriber_id")
  // Current node pointer. null until first step is queued.
  currentNodeId   String?  @map("current_node_id")
  // Engine state: queued | running | waiting_reply | sleeping | completed | failed | cancelled
  status          String   @default("queued")
  // For 'sleeping' and 'waiting_reply' — when to wake up / time out.
  resumeAt        DateTime? @map("resume_at")
  // For 'waiting_reply' — variable name to store the reply into.
  waitingForVar   String?  @map("waiting_for_var")
  // Per-run scratch storage (used by ai_reply, http_request results, etc).
  context         Json     @default("{}")
  // Diagnostic: last error if status=failed.
  lastError       String?  @map("last_error") @db.Text
  // The positional node ID this run was scheduled FROM. When the
  // subscriber advances to a new positional node, any sleeping/waiting
  // run with positionGroupId == old position is auto-cancelled.
  // null = run is not tied to a position (top-level trigger, broadcast,
  // CRM event etc.) and is immune to position-change cancellation.
  positionGroupId String?  @map("position_group_id")
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")

  flow            TgFlow        @relation(fields: [flowId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([status, resumeAt])
  @@index([subscriberId, status])
  @@index([flowId, status])
  @@index([subscriberId, positionGroupId, status])
  @@map("tg_flow_runs")
}

model TgBroadcast {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  name            String
  // Message payload (text/buttons/media). See lib/tg/flow-schema.ts.
  message         Json
  // Targeting: { allActive: bool, tagsAny: [], tagsAll: [], excludeTags: [], subscriberIds?: [] }
  filter          Json
  status          String   @default("draft") // draft | scheduled | sending | completed | cancelled | failed
  scheduledAt     DateTime? @map("scheduled_at")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  totalRecipients Int      @default(0) @map("total_recipients")
  sentCount       Int      @default(0) @map("sent_count")
  failedCount     Int      @default(0) @map("failed_count")
  blockedCount    Int      @default(0) @map("blocked_count")
  createdById     String?  @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  recipients      TgBroadcastRecipient[]

  @@index([botId, status])
  @@index([status, scheduledAt])
  @@map("tg_broadcasts")
}

model TgBroadcastRecipient {
  id              String   @id @default(uuid())
  broadcastId     String   @map("broadcast_id")
  subscriberId    String   @map("subscriber_id")
  // pending | sent | failed | blocked | skipped
  status          String   @default("pending")
  tgMessageId     String?  @map("tg_message_id")
  errorCode       Int?     @map("error_code")
  errorMessage    String?  @map("error_message") @db.Text
  attempts        Int      @default(0)
  nextAttemptAt   DateTime? @map("next_attempt_at")
  sentAt          DateTime? @map("sent_at")

  broadcast       TgBroadcast   @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, subscriberId])
  @@index([broadcastId, status])
  @@index([status, nextAttemptAt])
  @@map("tg_broadcast_recipients")
}

// Scheduled-flow — запуск целого флоу для отфильтрованной аудитории в
// заданный момент времени. Это «отложенный лидмагнит» или «дожим в
// субботу 10:00»: в отличие от broadcast (одно сообщение), здесь
// поднимается полноценный flow run для каждого подписчика.
//
// Статусы:
//   scheduled — запланирован, ждёт момента
//   running   — воркер начал поднимать runs
//   completed — все runs созданы (или filter оказался пустым)
//   cancelled — отменён вручную
//   failed    — ошибка материализации
model TgScheduledFlow {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  flowId          String   @map("flow_id")
  name            String
  // То же содержимое, что у broadcast.filter (BroadcastFilter shape):
  // { allActive, tagsAny, tagsAll, excludeTags, subscriberIds }
  filter          Json
  scheduledAt     DateTime @map("scheduled_at")
  status          String   @default("scheduled")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  totalLaunched   Int      @default(0) @map("total_launched")
  totalFailed     Int      @default(0) @map("total_failed")
  lastError       String?  @map("last_error") @db.Text
  createdById     String?  @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, status])
  @@index([status, scheduledAt])
  @@map("tg_scheduled_flows")
}

model TgTrackingLink {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Short URL-safe payload (<=48 chars) used in t.me/<bot>?start=<slug>.
  slug            String
  name            String
  // Optional flow to enter on /start; if null — default bot flow.
  startFlowId     String?  @map("start_flow_id")
  // Tags applied to subscriber on first touch.
  applyTags       String[] @default([]) @map("apply_tags")
  // Arbitrary UTM-style fields, no fixed schema.
  utm             Json     @default("{}")
  clickCount      Int      @default(0) @map("click_count")
  subscribeCount  Int      @default(0) @map("subscribe_count")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime? @map("expires_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, slug])
  @@map("tg_tracking_links")
}

model TgEvent {
  id              String   @id @default(uuid())
  botId           String?  @map("bot_id")
  subscriberId    String?  @map("subscriber_id")
  // Discriminator. See lib/tg/events.ts for the registry.
  type            String
  // Free-form per-type payload.
  properties      Json     @default("{}")
  occurredAt      DateTime @default(now()) @map("occurred_at")

  bot             TgBot?        @relation(fields: [botId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([botId, type, occurredAt])
  @@index([subscriberId, occurredAt])
  @@map("tg_events")
}

// Admin audit log — recorded for every state-changing admin action.
// Read endpoints don't write here (too noisy); only mutations do.
// Retention is the operator's call; cron in lib/tg/audit.ts can prune
// rows older than 180 days.
model TgAuditLog {
  id              String   @id @default(uuid())
  // Who did it. null = system / cron.
  actorUserId     String?  @map("actor_user_id")
  actorEmail      String?  @map("actor_email")
  // Scope of the change.
  botId           String?  @map("bot_id")
  // Discriminator: "tg.flow.update", "tg.broadcast.send",
  // "tg.bot.delete" etc. Keeps the schema flat — no per-action table.
  action          String
  // Free-form payload: which IDs changed, what fields, IP, UA.
  details         Json     @default("{}")
  // Result code: "ok" | "denied" | "failed". Helps distinguish a
  // permission denial from a successful mutation.
  outcome         String   @default("ok")
  ip              String?
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([botId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("tg_audit_log")
}

// Lists are dynamic segments — an admin-curated bucket of subscribers
// used for targeting broadcasts and for `list_joined` / `list_left`
// reactive triggers in flows. Conceptually distinct from tags:
//   - Tag = a free-form label attached to a subscriber (denormalized
//     into TgSubscriber.tags[] for cheap GIN-index lookups).
//   - List = an explicit named bucket the subscriber belongs to,
//     with its own analytics counters.
// Mirror of SaleBot's "Списки" feature.
model TgList {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  name            String
  // Optional emoji or short prefix shown in the picker.
  icon            String?
  description     String?
  // Auto-add subscribers matching these tag predicates? Empty = manual.
  // Format: { all?: string[], any?: string[], none?: string[] }
  autoTagRules    Json     @default("{}") @map("auto_tag_rules")
  // Cached counts. Kept fresh by engine writes; can drift slightly
  // under heavy concurrency — fix by recomputing in cron if needed.
  memberCount     Int      @default(0) @map("member_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)
  members         TgSubscriberList[]

  @@unique([botId, name])
  @@index([botId])
  @@map("tg_lists")
}

// Many-to-many join: which subscribers are in which lists. Created /
// destroyed by addToList() / removeFromList() in lib/tg/lists.ts.
// joinedAt fires the `list_joined` trigger; deletion fires `list_left`.
model TgSubscriberList {
  id              String   @id @default(uuid())
  listId          String   @map("list_id")
  subscriberId    String   @map("subscriber_id")
  joinedAt        DateTime @default(now()) @map("joined_at")

  list            TgList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  subscriber      TgSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([listId, subscriberId])
  @@index([subscriberId])
  @@index([listId, joinedAt])
  @@map("tg_subscriber_lists")
}

// Typed custom fields for subscribers. Schema lives here; values live
// in TgSubscriber.customFields (a JSON bag keyed by `key`).
// Each field has a runtime type that the validator + UI honor.
//   text     → free text
//   number   → numeric (validated as parsable float)
//   date     → dd.mm.yyyy
//   email    → email regex
//   phone    → normalised via normalizePhone() helper
//   select   → one of `options[].value`
//   boolean  → "yes"/"no" or true/false
//   url      → URL regex
model TgCustomField {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Identifier used in templates / `wait_reply.saveAs = field.x`.
  // Must match /^[a-z][a-z0-9_]*$/ — enforced in API layer.
  key             String
  // Display label in admin UI.
  label           String
  // Type discriminator (see model docstring).
  type            String
  // Free-text help shown under the field in admin UI.
  description     String?
  // For type=select: array of { value, label }. JSON for flexibility.
  options         Json     @default("[]")
  // Optional regex applied on top of type validation (e.g. an email
  // field restricted to a specific corporate domain).
  validationRegex String?  @map("validation_regex")
  // True = required when an admin opens a subscriber profile. Engine
  // also surfaces required-but-empty fields in the lead sidebar.
  isRequired      Boolean  @default(false) @map("is_required")
  // Display order in lead sidebar.
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, key])
  @@index([botId, sortOrder])
  @@map("tg_custom_fields")
}

// Short redirect URLs used to track outbound clicks. When a flow
// button contains a URL, the engine can optionally rewrite it to
// /r/<slug> — clicks land here, get logged with subscriberId, and
// then 302 to the real target. Lets condition nodes branch on
// "did this subscriber click the link?" — a SaleBot staple for
// video-delivery and reminder-with-link funnels.
model TgRedirectLink {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // URL-safe random slug (10 chars). Globally unique to avoid leaking
  // bot identity in the URL.
  slug            String   @unique
  // Where to send the user after logging the click.
  targetUrl       String   @map("target_url") @db.Text
  // Optional flow/node the link was generated from (for analytics).
  sourceFlowId    String?  @map("source_flow_id")
  sourceNodeId    String?  @map("source_node_id")
  // Subscriber-specific links: when set, only this subscriber's
  // clicks are logged for this slug. Used by flows that want per-user
  // click attribution. Pass `?s=` query param at click time as a
  // back-up identifier in case the cookie / browser session is bad.
  subscriberId    String?  @map("subscriber_id")
  clickCount      Int      @default(0) @map("click_count")
  lastClickAt     DateTime? @map("last_click_at")
  createdAt       DateTime @default(now()) @map("created_at")
  expiresAt       DateTime? @map("expires_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([subscriberId])
  @@map("tg_redirect_links")
}

// Cached Telegram file_ids. Populated automatically when an admin
// (whitelisted via TgBot.adminChatIds) sends a media message to the
// bot — see lib/tg/inbound.ts. The same file_id can then be reused
// across messages and broadcasts without re-uploading, which is the
// only practical way to send large videos (>50MB upload cap on Bot API).
//
// `kind` mirrors the Telegram media discriminator we send back via
// sendPhoto / sendVideo / sendVoice / sendVideoNote / sendDocument /
// sendAudio / sendAnimation.
model TgMediaFile {
  id              String   @id @default(uuid())
  botId           String   @map("bot_id")
  // Stable Telegram file_id (valid for the bot that captured it).
  fileId          String   @map("file_id") @db.Text
  // Optional file_unique_id — same across all bots, used for dedup.
  fileUniqueId    String?  @map("file_unique_id")
  // Kind discriminator: photo | video | voice | video_note | document | audio | animation
  kind            String
  // Mime type when Telegram gives it (documents / audio / voice).
  mimeType        String?  @map("mime_type")
  // Bytes (Telegram's reported size; null for very small payloads).
  fileSize        Int?     @map("file_size")
  // For photos: pick the largest variant's dimensions.
  width           Int?
  height          Int?
  duration        Int?
  // Human label assigned in the admin UI. Defaults to original filename
  // for documents, or "voice 2026-05-13 14:32" for sender-recorded media.
  title           String?
  // Original filename when Telegram provides it (document/video/audio).
  fileName        String?  @map("file_name")
  // Cached preview thumb file_id, when available. Used for picker UI.
  thumbFileId     String?  @map("thumb_file_id")
  // Where it came from. 'inbound' = admin sent it to the bot. 'upload' =
  // uploaded directly through the admin panel and then echoed back via
  // sendDocument-self to get a file_id (deferred to future iter).
  source          String   @default("inbound")
  // Telegram chat_id of the admin who captured it — for audit.
  capturedByChatId String? @map("captured_by_chat_id")
  createdAt       DateTime @default(now()) @map("created_at")
  lastUsedAt      DateTime? @map("last_used_at")

  bot             TgBot    @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, kind, createdAt])
  @@index([botId, fileUniqueId])
  @@map("tg_media_files")
}

// =====================================================================
// Brief — анкета-бриф ученика (репетитора) для оформления визуальной
// упаковки на агрегаторах. Перенесено из Python-бота upakovka_pod_kluch.
// Один бриф на одного пользователя. Сохраняется пошагово (черновик),
// после завершения попадает в админ-панель /admin/briefs.
// =====================================================================
model Brief {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")

  // 'in_progress' | 'completed'
  status             String   @default("in_progress")

  // Для возобновления заполнения с того места, где остановились.
  // Соответствует ключу блока: 1..6, или 7 = финальный экран.
  currentStep        Int      @default(1) @map("current_step")

  // БЛОК 1: Основная информация
  fio                String?
  subject            String?
  targetAudience     String?  @map("target_audience") @db.Text
  painsGoals         String?  @map("pains_goals") @db.Text

  // БЛОК 4: Инфографика
  utp                String?  @db.Text
  educationText      String?  @map("education_text") @db.Text
  experience         String?  @db.Text
  achievements       String?  @db.Text
  methods            String?  @db.Text
  formats            String?  @db.Text

  // БЛОК 5: Как проходит обучение
  adIntro            String?  @map("ad_intro") @db.Text
  adProcess          String?  @map("ad_process") @db.Text
  adResult           String?  @map("ad_result") @db.Text

  // БЛОК 6: Визуальные предпочтения
  existingStyle      String?  @map("existing_style") @db.Text
  preferredStyle     String?  @map("preferred_style") @db.Text
  characterImage     String?  @map("character_image") @db.Text
  cardImpression     String?  @map("card_impression") @db.Text
  colorPreferences   String?  @map("color_preferences") @db.Text

  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  completedAt        DateTime? @map("completed_at")

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cases              BriefCase[]
  files              BriefFile[]

  @@index([status, completedAt])
  @@map("briefs")
}

model BriefCase {
  id          String   @id @default(uuid())
  briefId     String   @map("brief_id")
  orderIndex  Int      @default(0) @map("order_index")

  name        String?
  age         String?
  goal        String?  @db.Text
  beforeText  String?  @map("before_text") @db.Text
  duration    String?
  problems    String?  @db.Text
  afterText   String?  @map("after_text") @db.Text
  reviewText  String?  @map("review_text") @db.Text

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  brief       Brief        @relation(fields: [briefId], references: [id], onDelete: Cascade)
  files       BriefFile[]

  @@index([briefId, orderIndex])
  @@map("brief_cases")
}

// Загруженные файлы к брифу. file_type соответствует категории в боте:
// 'portrait' | 'selfie' | 'context' | 'review' | 'education' |
// 'materials' | 'style_example'.
// review-файлы могут быть привязаны к конкретному кейсу (caseId).
// Очередь AI-проверки ДЗ. Запись создаётся при сабмите вместо after()+sleep.
// Cron /api/tg-cron/homework-queue забирает записи где checkAfter <= now.
model HomeworkAIQueue {
  id            String   @id @default(uuid())
  submissionId  String   @unique @map("submission_id")
  lessonTitle   String   @map("lesson_title") @db.Text
  studentName   String   @map("student_name")
  studentAnswer String   @map("student_answer") @db.Text
  aiPrompt      String   @map("ai_prompt") @db.Text
  aiContext     String?  @map("ai_context") @db.Text
  imageFiles    Json     @map("image_files")
  lessonContent Json?    @map("lesson_content")
  checkAfter    DateTime @map("check_after")
  status        String   @default("waiting") // waiting | processing
  /// Режим обработки:
  ///   "auto_approve" — legacy путь: AI-checker сам решает, статус ДЗ переходит
  ///                    напрямую через /api/homework/ai-result (без куратора).
  ///   "suggest"      — путь «Проверка от Джарвикса»: AI-checker даёт вердикт
  ///                    в ai_suggested_* через async callback, куратор решает.
  mode          String   @default("auto_approve")
  attempts      Int      @default(0)
  lastError     String?  @map("last_error") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([status, checkAfter])
  @@map("homework_ai_queue")
}

model BriefFile {
  id          String   @id @default(uuid())
  briefId     String   @map("brief_id")
  caseId      String?  @map("case_id")

  fileType    String   @map("file_type")
  fileUrl     String   @map("file_url") @db.Text
  fileName    String?  @map("file_name")
  mimeType    String?  @map("mime_type")
  fileSize    Int?     @map("file_size")

  createdAt   DateTime @default(now()) @map("created_at")

  brief       Brief      @relation(fields: [briefId], references: [id], onDelete: Cascade)
  case        BriefCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([briefId, fileType])
  @@index([caseId])
  @@map("brief_files")
}

