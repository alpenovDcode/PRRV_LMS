# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/proryv_lms"
DIRECT_URL="postgresql://username:password@localhost:5432/proryv_lms"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets (Generate with: openssl rand -hex 32)
JWT_SECRET="your-secret-key-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"

# JWT Expiration
JWT_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="90d"

# Cloudflare Stream (Optional)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_STREAM_CUSTOMER_CODE=""
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_CODE=""

# Cloudflare Images (Optional)
CLOUDFLARE_IMAGES_ACCOUNT_ID=""
CLOUDFLARE_IMAGES_ACCOUNT_HASH=""
NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH=""

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# ALLOWED_ORIGIN is used for CORS headers in next.config.js
ALLOWED_ORIGIN="http://localhost:3000"
# ALLOWED_ORIGINS (comma-separated) is used for server-side CSRF validation
# In production, set this to your real domain(s), e.g.: "https://prrv.tech,https://www.prrv.tech"
# WARNING: If this is NOT set in production, all cross-origin requests will be BLOCKED.
ALLOWED_ORIGINS="http://localhost:3000"

# API Security (Generate with: openssl rand -hex 32)
API_SECRET_KEY="api_key"

# OpenClaw Integration
OPENCLAW_API_URL=""
OPENCLAW_API_KEY=""
OPENCLAW_AGENT_ID="main"

# Email Service (Optional - for notifications)
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASSWORD=""

# --- Marketing Email System (Спринт 0+) ---
# Архитектура: docs/MARKETING_EMAIL_SYSTEM.md
# Провайдер маркетинговых рассылок. yandex = текущий SMTP (тесты + узкие
# сегменты). unisender = продакшен после прогрева домена и заключения договора.
EMAIL_MARKETING_PROVIDER="yandex"
EMAIL_MARKETING_FROM_NAME="Прорыв"
# При yandex — этот адрес должен совпадать со SMTP_USER (иначе Yandex отклонит).
# При unisender — настроенный поддомен, например mail@mail.prrv.tech.
EMAIL_MARKETING_FROM_EMAIL="marketing@prrv.tech"
# База URL для tracking-пикселя и click-redirect. По умолчанию = NEXT_PUBLIC_APP_URL.
# EMAIL_TRACKING_BASE_URL="https://prrv.tech"

# Соль для sha256-хеширования IP в EmailEvent (privacy). Без неё используется
# JWT_SECRET — это работает, но не должно: при ротации JWT_SECRET все прошлые
# ipHash становятся нерекомбинируемыми. Сгенерируй отдельный, не ротируй.
# Generate with: openssl rand -hex 32
EMAIL_TRACKING_IP_SALT=""

# Секрет для HMAC-подписи click-tracking URL (защита от open-redirect).
# При генерации письма каждая ссылка подписывается этим ключом, route валидирует.
# Без него click-tracking работает в legacy-режиме (любой URL принимается)
# — НЕ используйте в проде. Generate with: openssl rand -hex 32
EMAIL_CLICK_SIGNING_SECRET=""

# Whitelist доменов разрешённых для fromEmail в кампаниях (через запятую).
# Защита от подмены адреса отправителя маркетологом ("ceo@google.com").
# Пример: "prrv.tech,mail.prrv.tech"
EMAIL_ALLOWED_FROM_DOMAINS=""

# Bearer для /api/email-cron/tick. Sidecar email-cron (docker-compose.prod.yml)
# курлит endpoint каждые 10 секунд и драйвит EmailDeliveryJob + EmailAutomationRun.
# Без секрета endpoint отвечает 503.
# Generate with: openssl rand -hex 32
EMAIL_CRON_SECRET=""

# --- Unisender API (Евгений впишет после возвращения и прогрева домена) ---
# UNISENDER_API_KEY=""
# UNISENDER_API_URL="https://api.unisender.com/ru/api"
# UNISENDER_WEBHOOK_SECRET=""
# UNISENDER_DEFAULT_LIST_ID=""

# Sentry (Optional - for error tracking)
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# --- Payments: CloudPayments (карты / СБП / Долями / Рассрочка CP) ---
# Какой провайдер используется по умолчанию через factory getProvider().
# ОТП работает рядом — выбирается на странице оплаты, не через эту переменную.
PAYMENT_PROVIDER="cloudpayments"
CP_PUBLIC_ID=""
CP_API_SECRET=""
# Single (одностадийная) или Dual (холд + ручной capture). Дефолт Single.
CP_PAYMENT_SCHEMA="Single"
# Список методов оплаты которые скрыть в виджете (через запятую). Поддерживаемые:
# Card, ForeignCard, Sbp, Dolyame, TcsInstallment, TinkoffPay, SberPay, MirPay
CP_RESTRICTED_METHODS=""

# --- Payments: ОТП Банк (кредит / рассрочка через smart-form) ---
# Альтернатива CloudPayments. Включается автоматически когда задан OTP_SHOP_CODE.
# Кнопка «В кредит или рассрочку (ОТП Банк)» появится на странице /pay/[orderId].
#
# Получи у куратора ОТП:
#   1. Shop Code партнёра (вид POS-XXXXX-XX-XXXXXX)
#   2. Логин/пароль технической учётной записи (для REST «Просмотр БП»)
#   3. IP-адреса ОТП, с которых будет приходить webhook (для whitelist)
# Передай куратору наш callback URL: https://prrv.tech/api/payments/webhook/otp
OTP_SHOP_CODE=""
OTP_LOGIN=""
OTP_PASSWORD=""
# IP whitelist webhook — через запятую. На проде задавать обязательно.
OTP_WEBHOOK_IPS=""
# Опционально (есть дефолты):
# OTP_CATEGORY="RGB_GOODS_CATEGORY_138"  # 138 = Образовательные услуги
# OTP_CREDIT_TYPE="2"                    # 1 Кредит / 2 Кредит+рассрочка / 3 Рассрочка
# OTP_KEYCLOAK_URL="https://poslogin.otpbank.ru/keycloak/auth/realms/PPU/protocol/openid-connect/token"
# OTP_API_BASE="https://ecom.otpbank.ru/smart-form-link/v1"
# OTP_SMART_FORM_BASE="https://ecom.otpbank.ru/smart-form"

# --- Payments: Freshcredit (BNPL/кредит/рассрочка через виджет партнёра) ---
# Третий способ оплаты рядом с CP и ОТП. Включается автоматически когда
# заданы FC_POINT_ID + FC_LOGIN + FC_PASSWORD. Кнопка «В кредит или
# рассрочку (Freshcredit)» появится на странице /pay/[orderId].
#
# Получи у курирующего менеджера Freshcredit:
#   1. POINT_ID — UUID торговой точки партнёра
#   2. Логин/пароль технической учётной записи
#   3. IP-адреса Freshcredit (для whitelist webhook)
# Передай менеджеру наш callback URL: https://prrv.tech/api/payments/webhook/freshcredit
FC_POINT_ID=""
FC_LOGIN=""
FC_PASSWORD=""
# IP whitelist webhook — через запятую. На проде задавать обязательно.
FC_WEBHOOK_IPS=""
# Опционально (есть дефолты):
# FC_GOODS_CODE="9"            # 9=Курсы и тренинги, 1=Ин.языки, 2=Другое обучение
# FC_CREDIT_TYPE="[1,2]"       # "1" Кредит / "2" Рассрочка / "[1,2]" Оба
# FC_CREDIT_TERMS="[12,24,36]" # сроки кредита; пусто = без ограничений
# FC_INSTALLMENTS_TERMS="[6,10,12]" # сроки рассрочки; пусто = без ограничений
# Среды:
# FC_API_BASE="https://formapi.freshcredit.ru:5046/widget-api"        # прод
# FC_WIDGET_BASE="https://widget.freshcredit.ru/order"                # прод
# для теста:
# FC_API_BASE="https://formapitest.freshcredit.ru:5047/widget-api"
# FC_WIDGET_BASE="https://widget-test.freshcredit.ru/order"
#
# ВРЕМЕННО: сервер Freshcredit отдаёт неполную цепочку TLS-сертификатов
# (нет промежуточного CA), из-за чего Node-fetch валит запрос ошибкой
# UNABLE_TO_VERIFY_LEAF_SIGNATURE. Этот флаг точечно отключает TLS-
# валидацию ТОЛЬКО для запросов к API Freshcredit. Все остальные fetch'и
# в приложении (CloudPayments, ОТП, Bitrix, S3, ...) работают со
# стандартной проверкой сертификатов. Когда Freshcredit починят SSL —
# поставить "false" (или убрать переменную). Дефолт сейчас — true.
# FC_INSECURE_TLS="true"

# Telegram bot — notifications when a new question is created
# 1. Create bot via @BotFather, get token
# 2. Add bot as admin to target group/channel
# 3. Send any message in the group, then call:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → find chat.id (negative for groups)
TELEGRAM_BOT_TOKEN="8764860796:AAGnhqry16r4n6x2Phyg_S9pTCr3mNm60ZY"
TELEGRAM_QUESTIONS_CHAT_ID="-4915953255"
# Chat ID группы "наставники 2.0" — куда приходит вызов наставника
MENTORS_TG_CHAT_ID="-100xxxxxxxxxx"

# --- Jarvis AI (первичный ответ на вопросы наставникам) ---
#
# JARVIS_PROVIDER — выбор провайдера:
#   "openai"    — OpenAI-совместимый API (Groq, OpenAI и др.)
#   "anthropic" — Anthropic Claude (нативный API)
#
# ── Локально (Groq, бесплатно) ──────────────────────────────────────────────
# Регистрация и ключ: console.groq.com → API Keys
# JARVIS_PROVIDER="openai"
# JARVIS_API_URL="https://api.groq.com/openai/v1"
# JARVIS_API_KEY="gsk_..."
# JARVIS_MODEL="llama-3.3-70b-versatile"
#
# ── Прод: OpenClaw (база знаний Прорыв, рекомендуется) ─────────────────────
# OpenClaw запущен локально на сервере, реквизиты берутся из OPENCLAW_* ниже
# JARVIS_PROVIDER="openclaw"
#
# ── Прод: Anthropic Claude ──────────────────────────────────────────────────
# Ключ: console.anthropic.com → API Keys
# JARVIS_PROVIDER="anthropic"
# JARVIS_API_KEY="sk-ant-..."
# JARVIS_MODEL="claude-3-5-haiku-20241022"   # быстрый и дешёвый
# JARVIS_API_URL не нужен при provider=anthropic
#
# ── Прод: OpenAI ────────────────────────────────────────────────────────────
# JARVIS_PROVIDER="openai"
# JARVIS_API_URL="https://api.openai.com/v1"
# JARVIS_API_KEY="sk-..."
# JARVIS_MODEL="gpt-4o-mini"
#
JARVIS_PROVIDER="openai"
JARVIS_API_URL="https://api.groq.com/openai/v1"
JARVIS_API_KEY=""
JARVIS_MODEL="llama-3.3-70b-versatile"
# Задержка перед ответом в мс. Прод: 300000 (5 мин). Локально: 15000 (15 сек).
JARVIS_DELAY_MS="300000"
# Секрет для cron endpoint. Генерация: openssl rand -hex 32
JARVIS_CRON_SECRET=""

# --- Bot platform (Telegram-first SaleBot/BotHelp replacement) ---
# Encryption key for stored Telegram bot tokens.
# Generate with: openssl rand -hex 32
# IMPORTANT: rotating this key invalidates all previously stored tokens.
TG_TOKEN_ENC_KEY=""
# Secret for the cron-tick endpoint. The tg-cron docker sidecar
# (configured in docker-compose.yml) consumes this every 20s to drive
# delay-nodes and wait_reply timeouts. Without it, those nodes never
# fire and runs hang in `sleeping` / `waiting_reply` forever.
# Generate with: openssl rand -hex 32
TG_CRON_SECRET=""

# Secret for the reviews-cron endpoint. Sidecar reviews-cron
# (docker-compose.prod.yml) использует его для авторизации, чтобы раз в
# сутки синкать Otzovik и Яндекс Карты в фоне.
# Generate with: openssl rand -hex 32
REVIEWS_CRON_SECRET=""

# Crawlbase tokens для проксирования скрапинга. Без них прод-сервер
# получает блокировки от Otzovik (507) и пустые страницы от Яндекс Карт.
# Зарегаться: https://crawlbase.com (1000 запросов/мес free-tier).
CRAWLBASE_NORMAL_TOKEN=""
CRAWLBASE_JS_TOKEN=""

# Externally-reachable base URL — used by redirect-tracking to build
# /r/<slug> click-through URLs in outbound buttons. Defaults to
# NEXT_PUBLIC_APP_URL above when unset.
# PUBLIC_APP_URL="https://prrv.tech"

# Node Environment
NODE_ENV="development"
